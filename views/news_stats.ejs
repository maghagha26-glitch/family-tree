<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>إحصائيات الأخبار التفاعلية</title>

  <script src="/theme.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries,line-clamp"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",
            primaryDark: "#00361A",
            accent: "#E5B869",
            "bg-light": "#F5F3F7",
            "bg-dark": "#050505",
            "card-light": "rgba(255, 255, 255, 0.8)",
            "card-dark": "rgba(15, 12, 25, 0.8)",
            "border-light": "rgba(0, 90, 43, 0.1)",
            "border-dark": "rgba(229, 184, 105, 0.1)",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .glass-panel { @apply backdrop-blur-2xl shadow-xl; }
    }
  </style>

  <style>
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #005A2B; border-radius: 10px; }
    html.dark ::-webkit-scrollbar-thumb { background: #E5B869; }

    #nexusCanvas {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0; pointer-events: auto;
    }

    html.dark .dark-toggle-icon-moon { display: none; }
    html:not(.dark) .dark-toggle-icon-sun { display: none; }

    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer { transform: translateX(110%); transition: transform .4s cubic-bezier(0.16, 1, 0.3, 1); }
    #mobileNavDrawer.isOpen { transform: translateX(0); }

    .stat-card,
    .chart-card,
    .list-card {
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      transform-style: preserve-3d;
    }
    .stat-card:hover,
    .chart-card:hover,
    .list-card:hover {
      transform: translateY(-4px);
      border-color: rgba(0, 90, 43, 0.25);
      box-shadow: 0 18px 45px rgba(0, 90, 43, 0.10);
    }
    html.dark .stat-card:hover,
    html.dark .chart-card:hover,
    html.dark .list-card:hover {
      border-color: rgba(229, 184, 105, 0.25);
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.65);
    }
    .tilt-content { transform: translateZ(24px); }

    .circle-bg { fill: none; stroke: #e5e7eb; stroke-width: 3.5; }
    html.dark .circle-bg { stroke: rgba(255,255,255,0.12); }
    .circle-progress {
      fill: none;
      stroke-width: 3.5;
      stroke-linecap: round;
      stroke-dasharray: 100;
      stroke-dashoffset: calc(100 - var(--percent));
      transition: stroke-dashoffset 1.5s ease-in-out;
    }

    .bg-primary,
    a.bg-primary,
    button.bg-primary {
      background-color: #005A2B !important;
      background-image: none !important;
    }
    .dark .dark\:bg-accent,
    html.dark .dark\:bg-accent {
      background-color: #E5B869 !important;
      background-image: none !important;
    }
    [class*="bg-gradient"] { background-image: none !important; }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");
    })();
  </script>
</head>

<body class="bg-bg-light dark:bg-bg-dark text-gray-800 dark:text-gray-200 font-sans h-screen flex overflow-hidden selection:bg-accent selection:text-primaryDark">

  <canvas id="nexusCanvas"></canvas>
  <div class="fixed inset-0 bg-gradient-to-b from-white/40 to-white/80 dark:from-black/40 dark:to-[#050505]/90 pointer-events-none z-[1]"></div>

  <aside class="relative z-20 hidden lg:flex flex-col w-[280px] h-[calc(100vh-2rem)] my-4 mx-4 bg-card-light dark:bg-card-dark glass-panel rounded-3xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
    <div class="flex items-center gap-3 p-6 border-b border-border-light dark:border-border-dark shrink-0">
      <div class="w-12 h-12 flex items-center justify-center rounded-2xl bg-primary dark:bg-accent text-white dark:text-black shadow-lg">
        <span class="material-symbols-outlined text-[28px]">shield_person</span>
      </div>
      <div>
        <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
        <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة المركزية</p>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-6">
      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">البيانات الرئيسية</p>

        <a href="/admin" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">group</span>
          إدارة الأفراد
        </a>

        <a href="/admin/pages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">history_edu</span> إدارة الصفحات
        </a>

        <a href="/admin/honor" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">workspace_premium</span> السير الذاتية
        </a>

        <a href="/admin/news" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent font-bold text-sm border border-primary/20 dark:border-accent/20 transition-all relative overflow-hidden shadow-sm">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-6 rounded-l-full bg-primary dark:bg-accent shadow-[0_0_10px_rgba(229,184,105,0.8)]"></div>
          <span class="material-symbols-outlined text-[22px]">newspaper</span> الأخبار والمناسبات
        </a>
      </div>

      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">النظام والموقع</p>

        <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">mail</span> رسائل الدعم
        </a>

        <a href="/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">account_tree</span> عرض الشجرة
        </a>
      </div>
    </nav>

    <div class="p-4 border-t border-border-light dark:border-border-dark shrink-0 m-2 rounded-2xl bg-white/50 dark:bg-black/30">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-cover bg-center border border-gray-200 dark:border-white/10 shadow-sm" style="background-image:url('/assets/default-avatar.png'); background-color: #ddd;"></div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-gray-900 dark:text-white truncate"><%= admin?.username || "مدير النظام" %></p>
          <p class="text-[10px] text-primary dark:text-accent uppercase tracking-widest mt-0.5 font-bold">Admin</p>
        </div>
        <form method="post" action="/admin/logout" class="m-0">
          <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="تسجيل خروج">
            <span class="material-symbols-outlined text-[18px]">logout</span>
          </button>
        </form>
      </div>
    </div>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 h-full relative z-10">
    <header class="flex items-center justify-between p-4 lg:p-8 shrink-0">
      <div class="flex items-center gap-3">
        <button id="mobileNavBtn" class="lg:hidden flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-primary dark:text-accent shadow-sm" type="button">
          <span class="material-symbols-outlined text-[24px]">menu</span>
        </button>

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary dark:text-white tracking-tight leading-none mb-1.5">إحصائيات الأخبار</h2>
          <div class="flex items-center gap-1.5 text-gray-500 text-[11px] font-bold uppercase tracking-widest">
            <span>لوحة الإدارة</span>
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            <span class="text-accent">تقارير الأخبار التفاعلية</span>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-gray-600 dark:text-accent shadow-sm hover:-translate-y-1 transition-transform" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined text-[22px] dark-toggle-icon-moon">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:block text-[24px]">light_mode</span>
        </button>

        <a href="/admin/news" class="flex items-center gap-2 px-6 h-12 rounded-2xl font-bold text-sm bg-primary dark:bg-accent text-white dark:text-black shadow-[0_5px_20px_rgba(0,90,43,0.28)] dark:shadow-[0_5px_20px_rgba(229,184,105,0.20)] hover:-translate-y-1 transition-transform">
          <span class="material-symbols-outlined text-[22px]">arrow_back</span>
          <span class="hidden sm:inline">الرجوع للأخبار</span>
        </a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-4 lg:px-8 pb-12">
      <div class="max-w-[100rem] mx-auto space-y-8">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 chart-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-6 shadow-sm" data-tilt data-tilt-max="2" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.08">
            <div class="tilt-content h-full flex flex-col">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-12 h-12 rounded-2xl bg-primary/10 dark:bg-accent/10 flex items-center justify-center text-primary dark:text-accent">
                  <span class="material-symbols-outlined text-[28px]">bar_chart</span>
                </div>
                <div>
                  <h3 class="font-black text-gray-900 dark:text-white text-lg">معدل التفاعل العام</h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 font-bold mt-1">المشاهدات والإعجابات والتعليقات</p>
                </div>
              </div>
              <div class="relative w-full h-72 flex-1">
                <canvas id="barChart"></canvas>
              </div>
            </div>
          </div>

          <div class="chart-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-6 shadow-sm" data-tilt data-tilt-max="4" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.08">
            <div class="tilt-content h-full flex flex-col">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-12 h-12 rounded-2xl bg-accent/10 dark:bg-accent/10 flex items-center justify-center text-[#cfae61] dark:text-accent">
                  <span class="material-symbols-outlined text-[28px]">donut_large</span>
                </div>
                <div>
                  <h3 class="font-black text-gray-900 dark:text-white text-lg">حالة الأخبار</h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 font-bold mt-1">منشور / مخفي / مثبت</p>
                </div>
              </div>
              <div class="relative w-full h-72 flex justify-center">
                <canvas id="doughnutChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-6">
          <%
            let totalSubs = newsStats.subscribersTotal || 1;
            let activeSubs = newsStats.subscribersActive || 0;
            let activePercent = Math.round((activeSubs / totalSubs) * 100);
          %>
          <div class="stat-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 shadow-sm relative overflow-hidden" data-tilt data-tilt-max="6" data-tilt-glare data-tilt-max-glare="0.1">
            <div class="tilt-content flex justify-between items-center gap-4">
              <div>
                <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">المشتركون النشطون</p>
                <h2 class="text-4xl font-black mt-1 text-primary dark:text-white"><%= activeSubs %></h2>
                <p class="text-xs text-gray-400 mt-2 font-bold">من أصل <%= totalSubs %> مشترك</p>
              </div>
              <div class="relative w-16 h-16 shrink-0">
                <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
                  <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                  <path class="circle-progress stroke-primary dark:stroke-accent" style="--percent: <%= activePercent %>;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                </svg>
                <div class="absolute inset-0 flex items-center justify-center font-black text-xs text-primary dark:text-accent">%<%= activePercent %></div>
              </div>
            </div>
          </div>

          <div class="stat-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 shadow-sm" data-tilt data-tilt-max="6" data-tilt-glare data-tilt-max-glare="0.1">
            <div class="tilt-content flex justify-between items-start gap-4">
              <div>
                <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">إجمالي الأخبار</p>
                <h2 class="text-4xl font-black mt-1 text-primary dark:text-white"><%= newsStats.newsTotal || 0 %></h2>
              </div>
              <div class="w-14 h-14 rounded-2xl bg-primary/10 dark:bg-accent/10 flex items-center justify-center text-primary dark:text-accent shadow-sm">
                <span class="material-symbols-outlined text-[30px]">library_books</span>
              </div>
            </div>
          </div>

          <div class="stat-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 shadow-sm" data-tilt data-tilt-max="6" data-tilt-glare data-tilt-max-glare="0.1">
            <div class="tilt-content flex justify-between items-start gap-4">
              <div>
                <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">الإشعارات المرسلة</p>
                <h2 class="text-4xl font-black mt-1 text-[#cfae61] dark:text-accent"><%= newsStats.notifications || 0 %></h2>
              </div>
              <div class="w-14 h-14 rounded-2xl bg-accent/10 dark:bg-accent/10 flex items-center justify-center text-[#cfae61] dark:text-accent shadow-sm">
                <span class="material-symbols-outlined text-[30px]">notifications_active</span>
              </div>
            </div>
          </div>

          <%
            let totalN = newsStats.newsTotal || 1;
            let pubN = newsStats.newsPublished || 0;
            let pubPercent = Math.round((pubN / totalN) * 100);
          %>
          <div class="stat-card bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 shadow-sm relative overflow-hidden" data-tilt data-tilt-max="6" data-tilt-glare data-tilt-max-glare="0.1">
            <div class="tilt-content flex justify-between items-center gap-4">
              <div>
                <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">المنشور فعلياً</p>
                <h2 class="text-4xl font-black mt-1 text-emerald-600 dark:text-emerald-400"><%= pubN %></h2>
                <p class="text-xs text-gray-400 mt-2 font-bold">خبر معروض للجمهور</p>
              </div>
              <div class="relative w-16 h-16 shrink-0">
                <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
                  <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                  <path class="circle-progress stroke-emerald-500" style="--percent: <%= pubPercent %>;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                </svg>
                <div class="absolute inset-0 flex items-center justify-center font-black text-xs text-emerald-600 dark:text-emerald-400">%<%= pubPercent %></div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
          <div class="list-card bg-card-light dark:bg-card-dark glass-panel rounded-3xl shadow-sm border border-border-light dark:border-border-dark p-6 flex flex-col h-full" data-tilt data-tilt-max="1" data-tilt-speed="1000">
            <div class="tilt-content">
              <div class="flex items-center gap-3 mb-6 pb-4 border-b border-border-light dark:border-border-dark">
                <div class="w-11 h-11 rounded-2xl bg-orange-50 dark:bg-orange-500/10 flex items-center justify-center text-orange-500">
                  <span class="material-symbols-outlined">local_fire_department</span>
                </div>
                <div>
                  <h2 class="text-xl font-black text-gray-900 dark:text-white">أكثر الأخبار مشاهدة</h2>
                  <p class="text-xs text-gray-500 dark:text-gray-400 font-bold mt-1">حسب عدد المشاهدات والتفاعل</p>
                </div>
              </div>

              <div class="flex-1 overflow-y-auto pr-1 custom-scrollbar" style="max-height: 420px;">
                <% if (!newsStats.topNews || newsStats.topNews.length === 0) { %>
                  <div class="flex flex-col items-center justify-center h-40 text-gray-400">
                    <span class="material-symbols-outlined text-4xl mb-2 opacity-50">inbox</span>
                    <p class="font-bold">لا توجد أخبار بعد لعرضها</p>
                  </div>
                <% } else { %>
                  <div class="space-y-3">
                    <% (newsStats.topNews || []).forEach(function(n, index) { %>
                      <div class="flex gap-4 items-center p-4 rounded-2xl bg-gray-50/70 dark:bg-white/5 hover:-translate-y-1 hover:shadow-md transition-all duration-300 border border-transparent hover:border-primary/20 dark:hover:border-accent/20">
                        <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary dark:bg-accent/10 dark:text-accent flex items-center justify-center font-black text-lg shrink-0 shadow-sm">
                          <%= index + 1 %>
                        </div>
                        <div class="flex-1 min-w-0">
                          <a href="/news/<%= n.id %>" target="_blank" class="font-black text-gray-900 dark:text-white hover:text-primary dark:hover:text-accent transition-colors line-clamp-1 text-base mb-1">
                            <%= n.title || ('خبر #' + n.id) %>
                          </a>
                          <div class="flex flex-wrap gap-3 text-xs text-gray-500 dark:text-gray-400 font-bold">
                            <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-sky-500">visibility</span> <%= n.views_count || 0 %></span>
                            <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-red-500">favorite</span> <%= n.likes_count || 0 %></span>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="list-card bg-card-light dark:bg-card-dark glass-panel rounded-3xl shadow-sm border border-border-light dark:border-border-dark p-6 flex flex-col h-full" data-tilt data-tilt-max="1" data-tilt-speed="1000">
            <div class="tilt-content">
              <div class="flex items-center gap-3 mb-6 pb-4 border-b border-border-light dark:border-border-dark">
                <div class="w-11 h-11 rounded-2xl bg-primary/10 dark:bg-accent/10 flex items-center justify-center text-primary dark:text-accent">
                  <span class="material-symbols-outlined">forum</span>
                </div>
                <div>
                  <h2 class="text-xl font-black text-gray-900 dark:text-white">آخر التعليقات</h2>
                  <p class="text-xs text-gray-500 dark:text-gray-400 font-bold mt-1">أحدث تفاعل على الأخبار</p>
                </div>
              </div>

              <div class="flex-1 overflow-y-auto pr-1 custom-scrollbar" style="max-height: 420px;">
                <% if (!newsStats.latestComments || newsStats.latestComments.length === 0) { %>
                  <div class="flex flex-col items-center justify-center h-40 text-gray-400">
                    <span class="material-symbols-outlined text-4xl mb-2 opacity-50">comments_disabled</span>
                    <p class="font-bold">لا توجد تعليقات بعد</p>
                  </div>
                <% } else { %>
                  <div class="space-y-3">
                    <% (newsStats.latestComments || []).forEach(function(c) { %>
                      <div class="p-4 rounded-2xl border border-gray-100 dark:border-white/10 hover:-translate-y-1 hover:border-primary/30 dark:hover:border-accent/30 transition-all duration-300 bg-white/70 dark:bg-white/5 shadow-sm">
                        <div class="flex items-center justify-between gap-3 mb-3">
                          <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary dark:text-accent text-xl">account_circle</span>
                            <p class="font-black text-primary dark:text-accent"><%= c.name || 'زائر' %></p>
                          </div>
                          <span class="text-xs font-bold text-gray-400 bg-gray-50 dark:bg-black/20 px-2 py-1 rounded-md"><%= c.created_at || '' %></span>
                        </div>
                        <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300 line-clamp-2 bg-gray-50/80 dark:bg-black/20 p-3 rounded-xl mb-3">
                          "<%= c.content || '' %>"
                        </p>
                        <a href="/news/<%= c.post_id %>" target="_blank" class="inline-flex items-center gap-1 text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-accent transition-colors">
                          <span class="material-symbols-outlined text-[16px]">turn_right</span>
                          على خبر: <%= c.news_title || ('خبر #' + c.post_id) %>
                        </a>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <aside id="mobileNavDrawer" class="fixed top-0 right-0 h-full w-[320px] max-w-[85vw] bg-card-light dark:bg-card-dark glass-panel border-l border-border-light dark:border-border-dark z-[90] flex flex-col">
    <div class="h-1.5 w-full bg-primary"></div>
    <div class="flex items-center justify-between p-6 border-b border-border-light dark:border-border-dark shrink-0">
      <div>
        <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
        <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة</p>
      </div>
      <button id="mobileNavClose" class="w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-500 hover:text-primary dark:hover:text-accent transition-colors" type="button">
        <span class="material-symbols-outlined text-[24px]">close</span>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-3 text-sm font-bold text-gray-700 dark:text-gray-300">
      <a href="/admin" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">group</span> إدارة الأفراد</a>
      <a href="/admin/pages" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">history_edu</span> إدارة الصفحات</a>
      <a href="/admin/honor" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">workspace_premium</span> السير الذاتية</a>
      <a href="/admin/news" class="flex items-center gap-3 px-4 py-4 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent transition-colors border border-primary/20 dark:border-accent/20"><span class="material-symbols-outlined">newspaper</span> الأخبار</a>
      <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">mail</span> رسائل الدعم</a>
      <div class="my-4 border-t border-border-light dark:border-border-dark"></div>
      <a href="/" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">account_tree</span> العودة للموقع</a>

      <form method="post" action="/admin/logout" class="m-0 mt-4">
        <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-4 rounded-2xl border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 bg-red-50/50 dark:bg-red-500/10 hover:bg-red-50 transition-colors">
          <span class="material-symbols-outlined">logout</span> تسجيل خروج
        </button>
      </form>
    </nav>
  </aside>

  <div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>

  <script>
    const statsData = {
      views: <%= newsStats.viewsTotal || 0 %>,
      likes: <%= newsStats.likesTotal || 0 %>,
      comments: <%= newsStats.commentsTotal || 0 %>,
      published: <%= newsStats.newsPublished || 0 %>,
      hidden: <%= newsStats.hidden || 0 %>,
      pinned: <%= newsStats.pinned || 0 %>
    };

    let barChart, doughnutChart;

    function initCharts() {
      const isDark = document.documentElement.classList.contains('dark');
      const textColor = isDark ? '#d1d5db' : '#4b5563';
      const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,90,43,0.08)';

      const ctxBar = document.getElementById('barChart')?.getContext('2d');
      if(ctxBar) {
        if(barChart) barChart.destroy();
        barChart = new Chart(ctxBar, {
          type: 'bar',
          data: {
            labels: ['المشاهدات', 'الإعجابات', 'التعليقات'],
            datasets: [{
              label: 'إجمالي التفاعل',
              data: [statsData.views, statsData.likes, statsData.comments],
              backgroundColor: ['#005A2B', '#E5B869', '#8b5cf6'],
              borderRadius: 10,
              barThickness: 42
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { grid: { color: gridColor }, ticks: { color: textColor, font: { family: 'Tajawal' } } },
              x: { grid: { display: false }, ticks: { color: textColor, font: { family: 'Tajawal', weight: 'bold' } } }
            }
          }
        });
      }

      const ctxDoughnut = document.getElementById('doughnutChart')?.getContext('2d');
      if(ctxDoughnut) {
        if(doughnutChart) doughnutChart.destroy();
        doughnutChart = new Chart(ctxDoughnut, {
          type: 'doughnut',
          data: {
            labels: ['منشور', 'مخفي', 'مثبت'],
            datasets: [{
              data: [statsData.published, statsData.hidden, statsData.pinned],
              backgroundColor: ['#10b981', '#ef4444', '#E5B869'],
              borderWidth: 0,
              hoverOffset: 5
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
              legend: { position: 'bottom', labels: { color: textColor, font: { family: 'Tajawal', weight: 'bold' }, padding: 18 } }
            }
          }
        });
      }
    }

    (function () {
      const btn = document.getElementById("themeBtn");
      function setTheme(next) {
        document.documentElement.setAttribute("data-theme", next);
        document.documentElement.classList.toggle("dark", next === "dark");
        localStorage.setItem("theme", next);
        if(window.initNexus) window.initNexus();
        initCharts();
      }
      btn?.addEventListener("click", () => {
        const cur = document.documentElement.getAttribute("data-theme") || "dark";
        setTheme(cur === "dark" ? "light" : "dark");
      });
    })();

    (function mobileNavInit(){
      const btn = document.getElementById("mobileNavBtn");
      const navDrawer = document.getElementById("mobileNavDrawer");
      const overlay = document.getElementById("mobileNavOverlay");
      const closeBtn = document.getElementById("mobileNavClose");

      function toggleNav() {
        navDrawer?.classList.toggle("isOpen");
        overlay?.classList.toggle("hidden");
      }

      btn?.addEventListener("click", toggleNav);
      closeBtn?.addEventListener("click", toggleNav);
      overlay?.addEventListener("click", toggleNav);
    })();

    (function() {
      const canvas = document.getElementById('nexusCanvas');
      if(!canvas) return;
      const ctx = canvas.getContext('2d');

      let width, height;
      let particles = [];
      const numParticles = window.innerWidth > 1024 ? 130 : 70;

      let mouseX = -1000;
      let mouseY = -1000;

      let dotColor, lineColor, connectionColor;

      window.initNexus = function() {
        const isDark = document.documentElement.classList.contains('dark');
        dotColor = isDark ? 'rgba(229, 184, 105, 0.55)' : 'rgba(0, 90, 43, 0.32)';
        lineColor = isDark ? 'rgba(229, 184, 105, 0.16)' : 'rgba(0, 90, 43, 0.09)';
        connectionColor = isDark ? '229, 184, 105' : '0, 90, 43';
      };

      function resize() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      }

      function initParticles() {
        particles = [];
        for (let i = 0; i < numParticles; i++) {
          particles.push({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            radius: Math.random() * 2.8 + 1.2
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, width, height);

        for (let i = 0; i < numParticles; i++) {
          const p = particles[i];
          p.x += p.vx;
          p.y += p.vy;

          if (p.x < 0 || p.x > width) p.vx *= -1;
          if (p.y < 0 || p.y > height) p.vy *= -1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fillStyle = dotColor;
          ctx.fill();

          const dxMouse = mouseX - p.x;
          const dyMouse = mouseY - p.y;
          const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);

          if (distMouse < 230) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(mouseX, mouseY);
            const opacity = 0.6 * (1 - distMouse / 230);
            ctx.strokeStyle = `rgba(${connectionColor}, ${opacity})`;
            ctx.lineWidth = 1;
            ctx.stroke();

            p.x += dxMouse * 0.014;
            p.y += dyMouse * 0.014;
          }

          for (let j = i + 1; j < numParticles; j++) {
            const p2 = particles[j];
            const dx = p.x - p2.x;
            const dy = p.y - p2.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 165) {
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(p2.x, p2.y);
              ctx.strokeStyle = lineColor;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }

        requestAnimationFrame(draw);
      }

      window.addEventListener('resize', () => { resize(); initParticles(); });
      window.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
      window.addEventListener('mouseout', () => { mouseX = -1000; mouseY = -1000; });

      window.initNexus();
      resize();
      initParticles();
      draw();
    })();

    document.addEventListener('DOMContentLoaded', () => {
      initCharts();
      if (window.VanillaTilt) {
        VanillaTilt.init(document.querySelectorAll("[data-tilt]"), { reverse: true });
      }
    });
  </script>

</body>
</html>
