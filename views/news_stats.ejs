<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>إحصائيات الأخبار التفاعلية</title>

  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet"/>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#1f637a",
            primary_light: "#2a82a1",
            gold: "#cfae61",
            gold_light: "#dfc17a",
            darkbg: "#0F1115",
            card: "#16191E",
          },
          fontFamily: {
            cairo: ["Cairo", "sans-serif"]
          }
        }
      }
    };
  </script>

  <style>
    /* تحسينات إضافية للتمرير */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1f637a; border-radius: 4px; }
    .dark ::-webkit-scrollbar-thumb { background: #cfae61; }

    /* أنيميشن دائرة النسبة - تم تعديل السماكة إلى 3.5 لأناقة أكبر */
    .circle-bg { fill: none; stroke: #e5e7eb; stroke-width: 3.5; }
    .dark .circle-bg { stroke: #374151; }
    .circle-progress {
      fill: none;
      stroke-width: 3.5;
      stroke-linecap: round;
      stroke-dasharray: 100;
      stroke-dashoffset: calc(100 - var(--percent));
      transition: stroke-dashoffset 1.5s ease-in-out;
    }
    
    /* الحفاظ على جودة 3D */
    .tilt-card {
      transform-style: preserve-3d;
    }
    .tilt-content {
      transform: translateZ(30px); /* إبراز المحتوى للأمام */
    }
  </style>
</head>

<body class="font-cairo bg-gray-50 dark:bg-darkbg text-gray-800 dark:text-gray-200 transition-colors duration-500 min-h-screen pb-10">

<div class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8">

  <div class="flex flex-col md:flex-row justify-between items-center gap-6 mb-8 bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800">
    <div class="flex items-center gap-4">
      <div class="p-3 bg-primary/10 dark:bg-gold/10 rounded-2xl">
        <span class="material-symbols-outlined text-4xl text-primary dark:text-gold">insights</span>
      </div>
      <div>
        <h1 class="text-3xl font-black text-gray-900 dark:text-white">لوحة إحصائيات الأخبار</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">تقارير ورسوم بيانية تفاعلية 3D</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <button onclick="toggleTheme()" class="p-3 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors shadow-sm">
        <span class="material-symbols-outlined" id="themeIcon">light_mode</span>
      </button>

      <a href="/admin/news" class="flex items-center gap-2 px-5 py-3 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 font-bold hover:bg-gray-200 dark:hover:bg-gray-700 transition-all shadow-sm">
        الرجوع للأخبار
      </a>
      <a href="/admin" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary_light dark:bg-gold dark:text-gray-900 dark:hover:bg-gold_light transition-all shadow-md hover:shadow-lg">
        لوحة الإدارة
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    
    <div class="lg:col-span-2 bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="2" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.1">
      <div class="tilt-content h-full flex flex-col">
        <h2 class="text-lg font-black text-gray-900 dark:text-white mb-4">📊 معدل التفاعل العام</h2>
        <div class="relative w-full h-64 flex-1">
          <canvas id="barChart"></canvas>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.1">
      <div class="tilt-content h-full flex flex-col items-center justify-center">
        <h2 class="text-lg font-black text-gray-900 dark:text-white mb-4 w-full text-right">🍩 حالة الأخبار</h2>
        <div class="relative w-full h-56 flex justify-center">
          <canvas id="doughnutChart"></canvas>
        </div>
      </div>
    </div>

  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">

    <% 
      let totalSubs = newsStats.subscribersTotal || 1;
      let activeSubs = newsStats.subscribersActive || 0;
      let activePercent = Math.round((activeSubs / totalSubs) * 100);
    %>
    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">المشتركون النشطون</p>
          <h2 class="text-4xl font-black mt-2 text-teal-600 dark:text-teal-400"><%= activeSubs %></h2>
          <p class="text-xs text-gray-400 mt-2">من أصل <%= totalSubs %> مشترك</p>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-teal-500" style="--percent: <%= activePercent %>;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-teal-600 dark:text-teal-400">
            %<%= activePercent %>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-start">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">إجمالي الأخبار</p>
          <h2 class="text-4xl font-black mt-2 text-gray-900 dark:text-white"><%= newsStats.newsTotal || 0 %></h2>
        </div>
        <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-2xl text-blue-600 dark:text-blue-400 shadow-inner">
          <span class="material-symbols-outlined text-3xl">library_books</span>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-start">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">الإشعارات المرسلة</p>
          <h2 class="text-4xl font-black mt-2 text-yellow-500 dark:text-yellow-400"><%= newsStats.notifications || 0 %></h2>
        </div>
        <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl text-yellow-600 dark:text-yellow-400 shadow-inner">
          <span class="material-symbols-outlined text-3xl">notifications_active</span>
        </div>
      </div>
    </div>

    <% 
      let totalN = newsStats.newsTotal || 1;
      let pubN = newsStats.newsPublished || 0;
      let pubPercent = Math.round((pubN / totalN) * 100);
    %>
    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">المنشور فعلياً</p>
          <h2 class="text-4xl font-black mt-2 text-emerald-600 dark:text-emerald-400"><%= pubN %></h2>
          <p class="text-xs text-gray-400 mt-2">خبر معروض للجمهور</p>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-emerald-500" style="--percent: <%= pubPercent %>;" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-emerald-600 dark:text-emerald-400">
            %<%= pubPercent %>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col h-full tilt-card" data-tilt data-tilt-max="1" data-tilt-speed="1000">
      <div class="tilt-content">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100 dark:border-gray-800">
          <div class="p-2 bg-orange-50 dark:bg-orange-900/20 rounded-lg text-orange-500">
            <span class="material-symbols-outlined">local_fire_department</span>
          </div>
          <h2 class="text-xl font-black text-gray-900 dark:text-white">أكثر الأخبار مشاهدة</h2>
        </div>

        <div class="flex-1 overflow-y-auto pr-2" style="max-height: 400px;">
          <% if (!newsStats.topNews || newsStats.topNews.length === 0) { %>
            <div class="flex flex-col items-center justify-center h-40 text-gray-400">
              <span class="material-symbols-outlined text-4xl mb-2 opacity-50">inbox</span>
              <p>لا توجد أخبار بعد لعرضها</p>
            </div>
          <% } else { %>
            <div class="space-y-4">
              <% (newsStats.topNews || []).forEach(function(n, index) { %>
                <div class="flex gap-4 items-center p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50 hover:-translate-y-1 hover:shadow-md transition-all duration-300 border border-transparent hover:border-primary/20">
                  <div class="w-12 h-12 rounded-full bg-primary/10 text-primary dark:bg-gold/10 dark:text-gold flex items-center justify-center font-black text-lg shrink-0 shadow-sm">
                    <%= index + 1 %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <a href="/news/<%= n.id %>" target="_blank" class="font-bold text-gray-900 dark:text-white hover:text-primary dark:hover:text-gold transition-colors line-clamp-1 text-lg mb-1">
                      <%= n.title || ('خبر #' + n.id) %>
                    </a>
                    <div class="flex flex-wrap gap-3 text-xs text-gray-500 dark:text-gray-400 font-bold">
                      <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-cyan-500">visibility</span> <%= n.views_count || 0 %></span>
                      <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-pink-500">favorite</span> <%= n.likes_count || 0 %></span>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col h-full tilt-card" data-tilt data-tilt-max="1" data-tilt-speed="1000">
      <div class="tilt-content">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100 dark:border-gray-800">
          <div class="p-2 bg-primary/10 dark:bg-gold/10 rounded-lg text-primary dark:text-gold">
            <span class="material-symbols-outlined">forum</span>
          </div>
          <h2 class="text-xl font-black text-gray-900 dark:text-white">آخر التعليقات</h2>
        </div>

        <div class="flex-1 overflow-y-auto pr-2" style="max-height: 400px;">
          <% if (!newsStats.latestComments || newsStats.latestComments.length === 0) { %>
            <div class="flex flex-col items-center justify-center h-40 text-gray-400">
              <span class="material-symbols-outlined text-4xl mb-2 opacity-50">comments_disabled</span>
              <p>لا توجد تعليقات بعد</p>
            </div>
          <% } else { %>
            <div class="space-y-4">
              <% (newsStats.latestComments || []).forEach(function(c) { %>
                <div class="p-4 rounded-2xl border border-gray-100 dark:border-gray-700 hover:-translate-y-1 hover:border-primary/50 dark:hover:border-gold/50 transition-all duration-300 bg-white dark:bg-card shadow-sm">
                  <div class="flex items-center justify-between gap-3 mb-3">
                    <div class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-gray-400 text-xl">account_circle</span>
                      <p class="font-black text-primary dark:text-gold"><%= c.name || 'زائر' %></p>
                    </div>
                    <span class="text-xs font-semibold text-gray-400 bg-gray-50 dark:bg-gray-800 px-2 py-1 rounded-md"><%= c.created_at || '' %></span>
                  </div>
                  <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300 line-clamp-2 bg-gray-50 dark:bg-gray-800/50 p-3 rounded-xl mb-3">
                    "<%= c.content || '' %>"
                  </p>
                  <a href="/news/<%= c.post_id %>" target="_blank" class="inline-flex items-center gap-1 text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-gold transition-colors">
                    <span class="material-symbols-outlined text-[16px]">turn_right</span>
                    على خبر: <%= c.news_title || ('خبر #' + c.post_id) %>
                  </a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  const statsData = {
    views: <%= newsStats.viewsTotal || 0 %>,
    likes: <%= newsStats.likesTotal || 0 %>,
    comments: <%= newsStats.commentsTotal || 0 %>,
    published: <%= newsStats.newsPublished || 0 %>,
    hidden: <%= newsStats.hidden || 0 %>,
    pinned: <%= newsStats.pinned || 0 %>
  };

  let barChart, doughnutChart;

  function initCharts() {
    const isDark = document.documentElement.classList.contains('dark');
    const textColor = isDark ? '#9ca3af' : '#4b5563';
    const gridColor = isDark ? '#1f2937' : '#f3f4f6';

    const ctxBar = document.getElementById('barChart').getContext('2d');
    if(barChart) barChart.destroy();
    barChart = new Chart(ctxBar, {
      type: 'bar',
      data: {
        labels: ['المشاهدات', 'الإعجابات', 'التعليقات'],
        datasets: [{
          label: 'إجمالي التفاعل',
          data: [statsData.views, statsData.likes, statsData.comments],
          backgroundColor: ['#06b6d4', '#ec4899', '#a855f7'],
          borderRadius: 8,
          barThickness: 40
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { grid: { color: gridColor }, ticks: { color: textColor, font: { family: 'Cairo' } } },
          x: { grid: { display: false }, ticks: { color: textColor, font: { family: 'Cairo', weight: 'bold' } } }
        }
      }
    });

    const ctxDoughnut = document.getElementById('doughnutChart').getContext('2d');
    if(doughnutChart) doughnutChart.destroy();
    doughnutChart = new Chart(ctxDoughnut, {
      type: 'doughnut',
      data: {
        labels: ['منشور', 'مخفي', 'مثبت'],
        datasets: [{
          data: [statsData.published, statsData.hidden, statsData.pinned],
          backgroundColor: ['#10b981', '#f43f5e', '#f59e0b'],
          borderWidth: 0,
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '70%',
        plugins: {
          legend: { position: 'bottom', labels: { color: textColor, font: { family: 'Cairo', weight: 'bold' }, padding: 20 } }
        }
      }
    });
  }

  function toggleTheme() {
    const htmlEl = document.documentElement;
    const themeIcon = document.getElementById('themeIcon');
    
    htmlEl.classList.toggle('dark');
    
    if (htmlEl.classList.contains('dark')) {
      themeIcon.textContent = 'dark_mode';
    } else {
      themeIcon.textContent = 'light_mode';
    }
    
    initCharts();
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCharts();
  });
</script>

</body>
</html>