<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>إحصائيات الأفراد التفاعلية</title>

  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet"/>

  <script src="https://cdn.tailwindcss.com"></script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#1f637a",
            primary_light: "#2a82a1",
            gold: "#cfae61",
            gold_light: "#dfc17a",
            darkbg: "#0F1115",
            card: "#16191E",
          },
          fontFamily: {
            cairo: ["Cairo", "sans-serif"]
          }
        }
      }
    };
  </script>

  <style>
    /* تحسينات إضافية للتمرير (Scrollbar) */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1f637a; border-radius: 4px; }
    .dark ::-webkit-scrollbar-thumb { background: #cfae61; }

    /* أنيميشن دائرة النسبة - تم تقليل سماكة الخط من 8 إلى 3.5 لأناقة أكبر */
    .circle-bg { fill: none; stroke: #e5e7eb; stroke-width: 3.5; }
    .dark .circle-bg { stroke: #374151; }
    .circle-progress {
      fill: none;
      stroke-width: 3.5;
      stroke-linecap: round;
      stroke-dasharray: 100;
      transition: stroke-dashoffset 1.5s ease-in-out;
    }

    /* الحفاظ على جودة 3D */
    .tilt-card { transform-style: preserve-3d; }
    .tilt-content { transform: translateZ(30px); }
  </style>
</head>

<body class="font-cairo bg-gray-50 dark:bg-darkbg text-gray-800 dark:text-gray-200 transition-colors duration-500 min-h-screen pb-10">


<%
  // حساب آمن للأسماء المتكررة في حالة عدم إرسال repeatedCount من السيرفر
  personStats = personStats || {};
  personStats.recentPersons = personStats.recentPersons || [];
  personStats.repeatedNames = personStats.repeatedNames || [];
  personStats.repeatedCount = Number(
    personStats.repeatedCount ??
    personStats.duplicateNamesCount ??
    personStats.repeated_names_count ??
    personStats.repeatedNamesCount ??
    personStats.repeatedNames.length ??
    0
  );
%>

<div class="max-w-7xl mx-auto p-4 md:p-6 lg:p-8">

  <div class="flex flex-col md:flex-row justify-between items-center gap-6 mb-8 bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800">
    <div class="flex items-center gap-4">
      <div class="p-3 bg-primary/10 dark:bg-gold/10 rounded-2xl">
        <span class="material-symbols-outlined text-4xl text-primary dark:text-gold">monitoring</span>
      </div>
      <div>
        <h1 class="text-3xl font-black text-gray-900 dark:text-white">إحصائيات الأفراد</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">تقارير ورسوم بيانية تفاعلية 3D</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <button onclick="toggleTheme()" class="p-3 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors shadow-sm" title="تبديل المظهر">
        <span class="material-symbols-outlined" id="themeIcon">light_mode</span>
      </button>

      <a href="/admin" class="flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary_light dark:bg-gold dark:text-gray-900 dark:hover:bg-gold_light transition-all shadow-md hover:shadow-lg">
        <span class="material-symbols-outlined text-sm">arrow_forward</span>
        الرجوع للإدارة
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    
    <div class="lg:col-span-2 bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="2" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.1">
      <div class="tilt-content h-full flex flex-col">
        <h2 class="text-lg font-black text-gray-900 dark:text-white mb-4">📈 مقارنة الحالة (أحياء / متوفين)</h2>
        <div class="relative w-full h-64 flex-1">
          <canvas id="statusChart"></canvas>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.1">
      <div class="tilt-content h-full flex flex-col items-center justify-center">
        <h2 class="text-lg font-black text-gray-900 dark:text-white mb-4 w-full text-right"> توزيع الجنس</h2>
        <div class="relative w-full h-56 flex justify-center">
          <canvas id="genderChart"></canvas>
        </div>
      </div>
    </div>

  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-start">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">إجمالي الأفراد</p>
          <h2 class="text-4xl font-black mt-3 text-gray-900 dark:text-white"><%= personStats.total %></h2>
        </div>
        <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-2xl text-blue-600 dark:text-blue-400 shadow-inner">
          <span class="material-symbols-outlined text-3xl">groups</span>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-start">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">الأسماء المتكررة</p>
          <h2 class="text-4xl font-black mt-3 text-gray-900 dark:text-white"><%= personStats.repeatedCount || 0 %></h2>
        </div>
        <div class="p-4 bg-purple-50 dark:bg-purple-900/20 rounded-2xl text-purple-600 dark:text-purple-400 shadow-inner">
          <span class="material-symbols-outlined text-3xl">content_copy</span>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">الأحياء</p>
          <h2 class="text-4xl font-black mt-2 text-emerald-600 dark:text-emerald-400"><%= personStats.alive %></h2>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-emerald-500" style="stroke-dashoffset: calc(100 - <%= personStats.alivePercent %>);" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-emerald-600 dark:text-emerald-400">
            %<%= personStats.alivePercent %>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">المتوفين</p>
          <h2 class="text-4xl font-black mt-2 text-rose-600 dark:text-rose-400"><%= personStats.deceased %></h2>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-rose-500" style="stroke-dashoffset: calc(100 - <%= personStats.deceasedPercent %>);" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-rose-600 dark:text-rose-400">
            %<%= personStats.deceasedPercent %>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">الرجال</p>
          <h2 class="text-4xl font-black mt-2 text-cyan-600 dark:text-cyan-400"><%= personStats.males %></h2>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-cyan-500" style="stroke-dashoffset: calc(100 - <%= personStats.malePercent %>);" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-cyan-600 dark:text-cyan-400">
            %<%= personStats.malePercent %>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 tilt-card relative overflow-hidden" data-tilt data-tilt-max="10" data-tilt-glare data-tilt-max-glare="0.2">
      <div class="tilt-content flex justify-between items-center">
        <div>
          <p class="text-sm font-bold text-gray-500 dark:text-gray-400">النساء</p>
          <h2 class="text-4xl font-black mt-2 text-pink-600 dark:text-pink-400"><%= personStats.females %></h2>
        </div>
        <div class="relative w-14 h-14 shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="circle-progress stroke-pink-500" style="stroke-dashoffset: calc(100 - <%= personStats.femalePercent %>);" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center font-bold text-xs text-pink-600 dark:text-pink-400">
            %<%= personStats.femalePercent %>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    
    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col h-full tilt-card" data-tilt data-tilt-max="1" data-tilt-speed="1000">
      <div class="tilt-content">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100 dark:border-gray-800">
          <div class="p-2 bg-primary/10 dark:bg-gold/10 rounded-lg text-primary dark:text-gold">
            <span class="material-symbols-outlined">person_add</span>
          </div>
          <h2 class="text-xl font-black text-gray-900 dark:text-white">آخر المضافين</h2>
        </div>

        <div class="flex-1 overflow-y-auto pr-2" style="max-height: 400px;">
          <% if (!personStats.recentPersons.length) { %>
            <div class="flex flex-col items-center justify-center h-40 text-gray-400">
              <span class="material-symbols-outlined text-4xl mb-2 opacity-50">inbox</span>
              <p>لا يوجد بيانات لعرضها</p>
            </div>
          <% } else { %>
            <div class="space-y-4">
              <% personStats.recentPersons.forEach(p => { %>
                <div class="flex items-center justify-between p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50 hover:-translate-y-1 hover:shadow-md transition-all duration-300 border border-transparent hover:border-primary/20">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white <%= p.gender === 'male' ? 'bg-cyan-500' : 'bg-pink-500' %> shadow-sm shrink-0">
                      <span class="material-symbols-outlined text-xl"><%= p.gender === 'male' ? 'man' : 'woman' %></span>
                    </div>
                    <div>
                      <p class="font-bold text-gray-900 dark:text-gray-100 text-lg"><%= p.name %></p>
                      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                        <%= p.gender === 'male' ? 'ذكر' : 'أنثى' %>
                      </p>
                    </div>
                  </div>
                  <span class="px-3 py-1 rounded-full text-xs font-bold shrink-0 <%= p.is_deceased ? 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400' : 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' %>">
                    <%= p.is_deceased ? 'متوفي' : 'حي' %>
                  </span>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-card p-6 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col h-full tilt-card" data-tilt data-tilt-max="1" data-tilt-speed="1000">
      <div class="tilt-content">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100 dark:border-gray-800">
          <div class="p-2 bg-primary/10 dark:bg-gold/10 rounded-lg text-primary dark:text-gold">
            <span class="material-symbols-outlined">repeat</span>
          </div>
          <h2 class="text-xl font-black text-gray-900 dark:text-white">الأسماء المتكررة</h2>
        </div>

        <div class="flex-1 overflow-y-auto pr-2" style="max-height: 400px;">
          <% if (!personStats.repeatedNames.length) { %>
            <div class="flex flex-col items-center justify-center h-40 text-gray-400">
              <span class="material-symbols-outlined text-4xl mb-2 opacity-50">verified</span>
              <p>لا توجد أسماء مكررة</p>
            </div>
          <% } else { %>
            <div class="space-y-3">
              <% personStats.repeatedNames.forEach(r => { %>
                <div class="flex items-center justify-between p-4 rounded-2xl border border-gray-100 dark:border-gray-700 hover:-translate-y-1 hover:border-primary dark:hover:border-gold transition-all duration-300 group bg-white dark:bg-card shadow-sm">
                  <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-gray-400 group-hover:text-primary dark:group-hover:text-gold transition-colors">person</span>
                    <span class="font-bold text-gray-800 dark:text-gray-200 text-lg"><%= r.name %></span>
                  </div>
                  <div class="flex items-center gap-2 bg-gray-50 dark:bg-gray-800 px-4 py-2 rounded-xl border border-gray-100 dark:border-gray-700 shrink-0">
                    <span class="text-sm text-gray-500 dark:text-gray-400">تكرار:</span>
                    <span class="font-black text-xl text-primary dark:text-gold"><%= r.count %></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>

</div>

<script>
  const statsData = {
    alive: <%= personStats.alive || 0 %>,
    deceased: <%= personStats.deceased || 0 %>,
    males: <%= personStats.males || 0 %>,
    females: <%= personStats.females || 0 %>
  };

  let statusChart, genderChart;

  function initCharts() {
    const isDark = document.documentElement.classList.contains('dark');
    const textColor = isDark ? '#9ca3af' : '#4b5563';
    const gridColor = isDark ? '#1f2937' : '#f3f4f6';

    const ctxStatus = document.getElementById('statusChart').getContext('2d');
    if(statusChart) statusChart.destroy();
    statusChart = new Chart(ctxStatus, {
      type: 'bar',
      data: {
        labels: ['الأحياء', 'المتوفين'],
        datasets: [{
          label: 'العدد الإجمالي',
          data: [statsData.alive, statsData.deceased],
          backgroundColor: ['#10b981', '#f43f5e'],
          borderRadius: 8,
          barThickness: 50
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { grid: { color: gridColor }, ticks: { color: textColor, font: { family: 'Cairo' } } },
          x: { grid: { display: false }, ticks: { color: textColor, font: { family: 'Cairo', weight: 'bold' } } }
        }
      }
    });

    const ctxGender = document.getElementById('genderChart').getContext('2d');
    if(genderChart) genderChart.destroy();
    genderChart = new Chart(ctxGender, {
      type: 'doughnut',
      data: {
        labels: ['الرجال', 'النساء'],
        datasets: [{
          data: [statsData.males, statsData.females],
          backgroundColor: ['#06b6d4', '#ec4899'],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '75%',
        plugins: {
          legend: { position: 'bottom', labels: { color: textColor, font: { family: 'Cairo', weight: 'bold' }, padding: 20 } }
        }
      }
    });
  }

  function toggleTheme() {
    const htmlEl = document.documentElement;
    const themeIcon = document.getElementById('themeIcon');
    
    htmlEl.classList.toggle('dark');
    
    if (htmlEl.classList.contains('dark')) {
      themeIcon.textContent = 'dark_mode';
    } else {
      themeIcon.textContent = 'light_mode';
    }
    
    initCharts();
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCharts();
  });
</script>

</body>
</html>