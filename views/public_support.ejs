            <a class="glass-premium bg-white/80 dark:bg-black/50 p-5 rounded-2xl flex items-center gap-4 group hover:-translate-y-1 hover:shadow-xl hover:border-blue-500/50 transition-all cursor-pointer" href="<%= emailHref %>">
              <div class="size-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-500 group-hover:bg-blue-500 group-hover:text-white transition-colors shadow-inner">
