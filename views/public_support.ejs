<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= page?.title || "الدعم" %> - شجرة العائلة</title>

  <script src="/theme.js"></script>
  <link rel="stylesheet" href="/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",     /* الأخضر الملكي */
            primaryDark: "#003D1D", 
            accent: "#E5B869",      /* ذهب سائل */
            "background-light": "#F8F8F6",
            "background-dark": "#050505",
            "bg-charcoal": "#050505",
            "bg-card": "#0A0A0A",
            "text-cream": "#FAFAFA",
            "muted-slate": "#71717A",
            gold: "#E5B869",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
          backgroundImage: {
            "islamic-pattern": "url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23E5B869' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")",
          }
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .glass-premium { @apply backdrop-blur-2xl border border-white/20 dark:border-white/5; }
    }
  </style>

  <style>
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #E5B869; border-radius: 4px; }

    /* الإضاءة المحيطية (Ambient Glow) */
    .ambient-glow {
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(0,90,43,0.15) 0%, transparent 70%);
      border-radius: 50%;
      top: -200px;
      left: -200px;
      pointer-events: none;
      z-index: 0;
    }
    .ambient-glow-2 {
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(229,184,105,0.1) 0%, transparent 70%);
      border-radius: 50%;
      bottom: -100px;
      right: -100px;
      pointer-events: none;
      z-index: 0;
    }

    /* حقول الإدخال الإبداعية (Fluid Inputs) */
    .premium-input {
      background: rgba(0, 0, 0, 0.03);
      border: none;
      border-bottom: 2px solid rgba(0, 0, 0, 0.1);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .dark .premium-input {
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    }
    .premium-input:focus {
      background: rgba(229, 184, 105, 0.05);
      border-bottom-color: #E5B869;
      box-shadow: 0 10px 20px -10px rgba(229, 184, 105, 0.2);
      outline: none;
      transform: translateY(-2px);
    }

    /* تصميم بطاقة البنك VIP (Black Card Style) */
    .vip-bank-card {
      background: linear-gradient(135deg, #1A1A1A 0%, #0A0A0A 100%);
      border: 1px solid rgba(229,184,105,0.2);
      box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
      position: relative;
      overflow: hidden;
      isolation: isolate;
    }
    .vip-bank-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(45deg, transparent, transparent 2px, rgba(255,255,255,0.02) 2px, rgba(255,255,255,0.02) 4px);
      z-index: 1;
      pointer-events: none;
    }
    /* لمعة البطاقة */
    .vip-bank-card::after {
      content: '';
      position: absolute;
      top: -50%; left: -50%;
      width: 200%; height: 200%;
      background: linear-gradient(to bottom right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0) 100%);
      transform: rotate(45deg);
      transition: transform 0.8s ease;
      z-index: 2;
      pointer-events: none;
    }
    .vip-bank-card:hover::after {
      transform: rotate(45deg) translate(50%, 50%);
    }

    /* الشريحة الذكية (Chip) */
    .card-chip {
      width: 45px; height: 35px;
      background: linear-gradient(135deg, #E5B869, #D4AF37, #B8860B);
      border-radius: 6px;
      position: relative;
      box-shadow: inset 0 0 5px rgba(0,0,0,0.5);
      z-index: 3;
    }
    .card-chip::after {
      content: ''; position: absolute; inset: 4px;
      border: 1px solid rgba(0,0,0,0.2); border-radius: 2px;
      background: linear-gradient(90deg, transparent 48%, rgba(0,0,0,0.1) 48%, rgba(0,0,0,0.1) 52%, transparent 52%);
    }

    /* Mobile Nav */
    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer { transform: translateX(-110%); transition: transform .3s ease; }
    #mobileNavDrawer.isOpen { transform: translateX(0); }
    #mobileNavBtn[data-open="true"] .ico-open { display: none; }
    #mobileNavBtn[data-open="true"] .ico-close { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-open { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-close { display: none; }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");
    })();
  </script>
</head>

<body class="bg-background-light dark:bg-bg-charcoal text-gray-900 dark:text-text-cream font-sans min-h-screen flex flex-col overflow-x-hidden selection:bg-accent selection:text-background-dark transition-colors duration-300">

  <div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>
  <aside id="mobileNavDrawer" class="fixed top-0 left-0 h-full w-[320px] max-w-[85vw] bg-white dark:bg-bg-charcoal border-r border-gray-200 dark:border-white/10 shadow-2xl z-[90] flex flex-col">
    <div class="h-1.5 w-full bg-gradient-to-r from-gray-300 via-accent to-gray-300 dark:from-gray-800 dark:via-accent dark:to-gray-800"></div>
    <div class="flex items-center justify-between p-6 border-b border-gray-100 dark:border-white/5">
      <img class="h-10 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار العائلة" />
      <img class="h-10 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار العائلة" />
      <button id="mobileNavClose" class="text-gray-500 hover:text-accent transition-colors" type="button" aria-label="إغلاق القائمة">
        <span class="material-symbols-outlined text-[28px]">close</span>
      </button>
    </div>
    <nav class="p-6 flex flex-col gap-4 font-bold text-lg flex-grow text-gray-700 dark:text-gray-300" aria-label="قائمة الجوال">
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/">الشجرة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/about">نبذة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/honor">قائمة السير الذاتية</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/news">أخبار العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/tree-pdf">مشجرة العائلة</a>
      <a class="px-4 py-3 rounded-lg text-accent bg-accent/5 border-r-2 border-accent" href="/support">الدعم</a>
    </nav>
    <div class="p-6 border-t border-gray-100 dark:border-white/5">
      <a href="/admin/login" class="flex items-center justify-center gap-2 py-3 bg-primary text-white dark:bg-white dark:text-primary rounded-lg hover:opacity-90 transition-colors font-bold" title="تسجيل الدخول">
        <span class="material-symbols-outlined">login</span>
      </a>
    </div>
  </aside>

  <header class="sticky top-0 z-50 w-full bg-white/95 dark:bg-[#050505]/95 backdrop-blur-md border-b border-gray-200 dark:border-white/10">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center h-20 md:h-24">
      
      <div class="flex items-center gap-4">
        <a href="/" class="block shrink-0">
          <img class="h-14 md:h-20 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار العائلة" />
          <img class="h-14 md:h-20 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار العائلة" />
        </a>
        <div class="h-10 w-px bg-gray-300 dark:bg-white/20"></div>
        <div class="flex items-center justify-center">
           <h1 class="text-2xl md:text-3xl font-display text-primary dark:text-accent font-bold leading-none tracking-wide pt-1">الدعم</h1>
        </div>
      </div>

      <nav class="hidden lg:flex gap-6 xl:gap-8 items-center font-sans font-bold text-sm tracking-wide uppercase text-gray-600 dark:text-gray-400">
        <a class="hover:text-accent transition-colors" href="/">الشجرة</a>
        <a class="hover:text-accent transition-colors" href="/about">نبذة</a>
        <a class="hover:text-accent transition-colors" href="/honor">قائمة السير الذاتية</a>
        <a class="hover:text-accent transition-colors" href="/news">أخبار العائلة</a>
        <a class="hover:text-accent transition-colors" href="/tree-pdf">مشجرة العائلة</a>
        <a class="text-primary dark:text-white border-b-2 border-accent pb-1" href="/support">الدعم</a>
      </nav>

      <div class="flex items-center gap-3 shrink-0">
        <button id="uiThemeBtn" class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent hover:bg-gray-50 dark:hover:bg-white/5 transition-all" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined dark:hidden">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:inline text-accent">light_mode</span>
        </button>

        <a href="/admin/login" class="hidden sm:flex p-2.5 rounded-full bg-primary text-white dark:bg-white dark:text-black hover:opacity-90 transition-all shadow-md flex items-center justify-center" title="تسجيل الدخول">
          <span class="material-symbols-outlined text-[22px]">login</span>
        </a>

        <button id="mobileNavBtn" data-open="false" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-primary dark:text-accent hover:bg-gray-200 dark:hover:bg-white/10 transition-colors" type="button" aria-label="فتح القائمة">
          <span class="material-symbols-outlined text-[24px] ico-open">menu</span>
          <span class="material-symbols-outlined text-[24px] ico-close hidden">close</span>
        </button>
      </div>

    </div>
  </header>

  <main class="flex-1 relative">
    
    <div class="ambient-glow"></div>
    <div class="ambient-glow-2"></div>

    <section class="pt-20 pb-12 px-6 max-w-[90rem] mx-auto text-center relative z-10">
      <div class="absolute inset-0 bg-islamic-pattern opacity-100 dark:opacity-30 pointer-events-none"></div>

      <img src="/assets/logo-dark.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] opacity-[0.03] pointer-events-none hidden dark:block" alt="">
      <img src="/assets/logo-light.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] opacity-[0.03] pointer-events-none block dark:hidden" alt="">

      <div class="w-px h-12 bg-accent mx-auto mb-6 relative z-10"></div>
      
      <h1 class="text-5xl md:text-7xl font-display leading-tight mb-8 relative z-10 font-bold drop-shadow-sm dark:drop-shadow-none">
        <span class="text-primary dark:text-white transition-colors duration-300"><%= page?.title?.split(" ")[0] || "الدعم" %></span> <span class="text-accent"><%= page?.title?.substring(page?.title?.indexOf(" ") + 1) || "والشكاوى" %></span>
      </h1>
      
      <p class="text-base md:text-lg font-sans text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed relative z-10">
        <%= page?.subtitle || "نحن هنا للاستماع إليكم. مشاركتكم تساهم في تطوير منصة العائلة وتعزيز الروابط بيننا." %>
      </p>
    </section>

    <section class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8 pb-20 relative z-10">
      
      <% if (sent) { %>
        <div class="mb-8 rounded-2xl border border-green-200 bg-green-50 text-green-700 px-6 py-5 font-bold dark:bg-green-900/20 dark:border-green-800/30 dark:text-green-400 text-center text-lg shadow-sm">
          <div class="flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">check_circle</span>
            <span>تم إرسال رسالتكم بنجاح. شكراً لتواصلكم معنا.</span>
          </div>
        </div>
      <% } %>

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-start">
        
        <div class="flex-1 w-full glass-premium bg-white/90 dark:bg-[#0A0A0A]/90 shadow-2xl rounded-[2rem] overflow-hidden relative">
          <div class="h-2 w-full bg-gradient-to-r from-primary via-accent to-primaryDark"></div>
          
          <div class="p-8 md:p-12 flex flex-col gap-10">

            <div class="rounded-xl bg-gray-50 dark:bg-[#111] border border-gray-200 dark:border-white/5 p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="size-10 rounded-full bg-accent/10 flex items-center justify-center text-accent">
                  <span class="material-symbols-outlined text-[20px]">info</span>
                </div>
                <div>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white">تعليمات الدعم</h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">يرجى الاطلاع قبل الإرسال</p>
                </div>
              </div>
              <div class="text-sm font-sans text-gray-700 dark:text-gray-300 leading-relaxed">
                <%= (page?.content || "اكتب تعليمات الدعم هنا من لوحة الإدارة.").replace(/\n/g,"<br>") %>
              </div>
            </div>

            <div class="flex items-center gap-3 border-b border-gray-200 dark:border-white/10 pb-4">
              <div class="size-10 rounded-full bg-primary/10 dark:bg-white/5 flex items-center justify-center text-primary dark:text-white">
                <span class="material-symbols-outlined text-[20px]">mail</span>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">نموذج التواصل المباشر</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-widest mt-1">يرجى ملء البيانات التالية بدقة</p>
              </div>
            </div>

            <form method="post" action="/support/send" class="grid grid-cols-1 md:grid-cols-2 gap-8">
              
              <label class="flex flex-col gap-2 relative group">
                <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest px-2">الاسم الكريم</span>
                <input name="sender_name" required
                  class="premium-input w-full h-14 rounded-t-xl px-4 text-gray-900 dark:text-white placeholder:text-gray-400 font-sans font-bold text-base"
                  placeholder="أدخل اسمك" type="text"/>
                <span class="material-symbols-outlined absolute left-4 top-1/2 translate-y-1 text-gray-400 group-focus-within:text-accent transition-colors">person</span>
              </label>

              <label class="flex flex-col gap-2 relative group">
                <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest px-2">رقم التواصل (اختياري)</span>
                <input name="phone"
                  class="premium-input w-full h-14 rounded-t-xl px-4 text-gray-900 dark:text-white placeholder:text-gray-400 font-sans font-bold text-base dir-ltr text-right"
                  placeholder="05xxxxxxxx" type="tel"/>
                <span class="material-symbols-outlined absolute left-4 top-1/2 translate-y-1 text-gray-400 group-focus-within:text-accent transition-colors">call</span>
              </label>

              <label class="flex flex-col gap-2 md:col-span-2 relative group">
                <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest px-2">محتوى الرسالة</span>
                <textarea name="message" rows="5" required
                  class="premium-input w-full min-h-[140px] rounded-t-xl p-4 text-gray-900 dark:text-white placeholder:text-gray-400 font-sans font-bold text-base resize-y"
                  placeholder="اكتب تفاصيل مقترحك أو شكواك هنا..."></textarea>
                <span class="material-symbols-outlined absolute left-4 top-10 text-gray-400 group-focus-within:text-accent transition-colors">edit_note</span>
              </label>

              <div class="md:col-span-2 flex flex-col sm:flex-row gap-4 pt-6">
                <a class="w-full sm:w-auto px-8 h-14 rounded-xl font-bold text-sm border border-gray-200 dark:border-white/10 bg-white hover:bg-gray-50 text-gray-700 transition-all flex items-center justify-center dark:bg-black/50 dark:text-gray-300 dark:hover:bg-white/5" href="/">
                  إلغاء
                </a>
                <button class="w-full sm:w-auto flex-1 h-14 bg-gradient-to-l from-primary to-primaryDark dark:from-accent dark:to-[#D4AF37] text-white dark:text-black rounded-xl font-bold text-base hover:opacity-90 hover:shadow-[0_10px_20px_rgba(229,184,105,0.3)] transition-all flex items-center justify-center gap-2 group/btn" type="submit">
                  <span>إرسال الرسالة للمسؤول</span>
                  <span class="material-symbols-outlined group-hover/btn:-translate-x-2 transition-transform rtl:rotate-180">send</span>
                </button>
              </div>

            </form>
          </div>
        </div>

        <div class="w-full lg:w-[400px] shrink-0 flex flex-col gap-8">

          <% const fundName = (page?.fund_name || "").trim(); %>
          <% const bankName = (page?.bank_name || "").trim(); %>
          <% const accNum = (page?.account_number || "").trim(); %>

          <div class="vip-bank-card rounded-2xl p-8 flex flex-col gap-8">
            <div class="relative z-10 flex justify-between items-start mb-2">
              <div>
                <h3 class="text-2xl font-display font-bold text-white tracking-wide mb-1">صندوق العائلة</h3>
                <p class="text-[10px] text-accent uppercase tracking-widest font-bold"><%= bankName ? ("البنك: " + bankName) : "مساهمتكم دعم لمستقبلنا" %></p>
              </div>
              <span class="material-symbols-outlined text-white/50 text-[32px]">contactless</span>
            </div>

            <div class="relative z-10 mt-2">
              <div class="card-chip"></div>
            </div>

            <div class="relative z-10 flex flex-col gap-1 mt-4">
              <p class="text-[10px] text-accent uppercase tracking-widest font-bold mb-1">رقم الحساب / IBAN</p>
              <button type="button" id="ibanCopy" class="text-right w-full flex items-center justify-between group/copy focus:outline-none">
                <p id="ibanText" class="font-mono text-[22px] tracking-widest text-white drop-shadow-md dir-ltr flex-grow"><%= accNum || "—" %></p>
                <div class="bg-white/10 p-2 rounded-lg border border-white/20 group-hover/copy:bg-accent group-hover/copy:text-black transition-all flex flex-col items-center justify-center">
                   <span class="material-symbols-outlined text-[18px]">content_copy</span>
                </div>
              </button>
              <span id="ibanHint" class="text-xs text-accent font-bold opacity-0 transition-opacity mt-1">تم النسخ للذاكرة ✓</span>
            </div>

            <div class="relative z-10 mt-2 border-t border-white/10 pt-4">
              <p class="text-[9px] text-white/50 uppercase tracking-[0.2em] mb-1">الاسم المعتمد</p>
              <p class="font-display font-bold text-xl text-white tracking-wide"><%= fundName || "صندوق العائلة" %></p>
            </div>
          </div>

          <%
            const waRaw = (page?.whatsapp || "").trim();
            const waDigits = waRaw.replace(/[^\d]/g, "");
            const waHref = waDigits ? ("https://wa.me/" + waDigits) : "#";
            const email = (page?.email || "").trim();
            const emailHref = email ? ("mailto:" + email) : "#";
          %>

          <div class="flex flex-col gap-4">
            <a class="glass-premium bg-white/80 dark:bg-black/50 p-5 rounded-2xl flex items-center gap-4 group hover:-translate-y-1 hover:shadow-xl hover:border-green-500/50 transition-all cursor-pointer" href="<%= waHref %>" target="<%= waDigits ? '_blank' : '_self' %>">
              <div class="size-12 rounded-2xl bg-[#25D366]/10 flex items-center justify-center text-[#25D366] group-hover:bg-[#25D366] group-hover:text-white transition-colors shadow-inner">
                <svg class="size-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
