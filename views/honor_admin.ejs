    </div>

    <nav class="p-4 flex flex-col gap-2 overflow-y-auto h-[calc(100%-72px)]" aria-label="قائمة الجوال - الأدمن">
      <a class="group px-4 py-3 rounded-2xl font-extrabold border border-slate-200 dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/5 transition-colors flex items-center justify-between"
         href="/admin">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[20px] opacity-80">group</span>
          إدارة الأفراد
        </span>
        <span class="material-symbols-outlined text-[18px] opacity-40 group-hover:opacity-80">chevron_left</span>
      </a>

      <a class="group px-4 py-3 rounded-2xl font-extrabold border border-slate-200 dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/5 transition-colors flex items-center justify-between"
         href="/admin/pages">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[20px] opacity-80">history_edu</span>
