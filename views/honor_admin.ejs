      </a>

      <a class="group px-4 py-3 rounded-2xl font-extrabold border border-slate-200 dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/5 transition-colors flex items-center justify-between"
         href="/admin/honor">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[20px] opacity-80">workspace_premium</span>
          إدارة السير الذاتية
        </span>
        <span class="material-symbols-outlined text-[18px] opacity-40 group-hover:opacity-80">chevron_left</span>
      </a>

      <a class="group px-4 py-3 rounded-2xl font-extrabold border border-slate-200 dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/5 transition-colors flex items-center justify-between"
