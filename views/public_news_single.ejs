<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= post.title %> - أخبار العائلة</title>

  <script src="/theme.js"></script>
  <link rel="stylesheet" href="/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries,line-clamp"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",
            primaryDark: "#003D1D",
            accent: "#E5B869",
            "background-light": "#F8F8F6",
            "background-dark": "#050505",
            "card-light": "#FFFFFF",
            "card-dark": "#0A0A0A",
            "bg-charcoal": "#050505",
            "bg-card": "#0A0A0A",
            "text-cream": "#FAFAFA",
            "muted-slate": "#71717A",
            gold: "#E5B869",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
          backgroundImage: {
            "islamic-pattern": "url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23E5B869' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")",
          }
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    }
  </style>

  <style>
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #E5B869; border-radius: 4px; }

    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer{
      transform: translateX(-110%);
      transition: transform .3s cubic-bezier(.2,.9,.2,1);
    }
    #mobileNavDrawer.isOpen{ transform: translateX(0); }
    #mobileNavBtn[data-open="true"] .ico-open { display: none; }
    #mobileNavBtn[data-open="true"] .ico-close { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-open { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-close { display: none; }

    .royal-panel {
      background:
        linear-gradient(135deg, rgba(255,255,255,.92), rgba(255,255,255,.72)),
        radial-gradient(circle at top right, rgba(229,184,105,.14), transparent 45%);
    }
    .dark .royal-panel {
      background:
        linear-gradient(135deg, rgba(10,10,10,.92), rgba(5,5,5,.76)),
        radial-gradient(circle at top right, rgba(229,184,105,.16), transparent 45%);
    }

    .article-shell {
      position: relative;
      overflow: hidden;
      border-radius: 34px;
      border: 1px solid rgba(229,184,105,.24);
      background: rgba(255,255,255,.86);
      box-shadow: 0 24px 80px rgba(0,0,0,.10);
      isolation: isolate;
    }
    .dark .article-shell {
      background: linear-gradient(180deg, rgba(18,18,18,.95), rgba(7,7,7,.98));
      border-color: rgba(255,255,255,.10);
      box-shadow: 0 24px 80px rgba(0,0,0,.52);
    }

    .article-image-shell {
      position: relative;
      overflow: hidden;
      min-height: 300px;
      background: #eee;
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid rgba(229,184,105,.18);
    }
    .dark .article-image-shell { background: #050505; border-bottom-color: rgba(255,255,255,.08); }
    .article-image-shell::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(0,0,0,.58), transparent 58%),
        radial-gradient(circle at top right, rgba(229,184,105,.22), transparent 45%);
      z-index: 3;
      pointer-events: none;
    }
    .article-image-blur {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: blur(28px);
      transform: scale(1.18);
      opacity: .32;
      z-index: 1;
    }
    .article-image-main {
      position: relative;
      z-index: 2;
      width: auto;
      max-width: 100%;
      max-height: 76vh;
      object-fit: contain;
    }
    .article-date-badge {
      position: absolute;
      right: 24px;
      bottom: 24px;
      z-index: 6;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      max-width: calc(100% - 48px);
      padding: 9px 14px;
      border-radius: 999px;
      border: 1px solid rgba(229,184,105,.55);
      background: rgba(0,0,0,.56);
      color: #fff;
      backdrop-filter: blur(10px);
      font-size: 12px;
      font-weight: 900;
    }
    .article-content {
      position: relative;
      padding: 26px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,255,255,.96)),
        radial-gradient(circle at top left, rgba(229,184,105,.13), transparent 38%);
    }
    .dark .article-content {
      background:
        linear-gradient(180deg, rgba(13,13,13,.94), rgba(5,5,5,.99)),
        radial-gradient(circle at top left, rgba(229,184,105,.10), transparent 40%);
    }
    @media (min-width: 640px) { .article-content { padding: 40px; } }
    @media (min-width: 1024px) { .article-content { padding: 52px; } }
    @media (max-width: 640px) { .article-image-main { max-height: 58vh; } }

    .news-category-pill {
      width: fit-content;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(0,90,43,.08);
      color: #005A2B;
      border: 1px solid rgba(0,90,43,.12);
      font-size: 12px;
      font-weight: 900;
    }
    .dark .news-category-pill { color: #E5B869; background: rgba(229,184,105,.08); border-color: rgba(229,184,105,.16); }
    .news-separator {
      width: 70px;
      height: 2px;
      margin: 18px 0 22px auto;
      background: linear-gradient(to left, #E5B869, rgba(229,184,105,0));
    }
    .soft-card {
      border: 1px solid rgba(229,184,105,.20);
      background: rgba(255,255,255,.72);
      box-shadow: 0 14px 40px rgba(0,0,0,.06);
    }
    .dark .soft-card {
      border-color: rgba(255,255,255,.10);
      background: rgba(10,10,10,.72);
      box-shadow: 0 14px 40px rgba(0,0,0,.38);
    }
    .related-card {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      background: rgba(255,255,255,.86);
      border: 1px solid rgba(229,184,105,.22);
      box-shadow: 0 18px 45px rgba(0,0,0,.08);
      transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
    }
    .dark .related-card { background: linear-gradient(180deg, rgba(18,18,18,.95), rgba(7,7,7,.98)); border-color: rgba(255,255,255,.10); }
    .related-card:hover { transform: translateY(-7px); border-color: rgba(229,184,105,.55); box-shadow: 0 26px 70px rgba(0,0,0,.14); }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");

      const obs = new MutationObserver(() => {
        const t = document.documentElement.getAttribute("data-theme") || "dark";
        document.documentElement.classList.toggle("dark", t === "dark");
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    })();
  </script>
</head>

<body class="bg-background-light dark:bg-bg-charcoal text-gray-900 dark:text-text-cream font-sans min-h-screen flex flex-col overflow-x-hidden selection:bg-accent selection:text-background-dark transition-colors duration-300">

  <div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>
  <aside id="mobileNavDrawer" class="fixed top-0 left-0 h-full w-[320px] max-w-[85vw] bg-white dark:bg-bg-charcoal border-r border-gray-200 dark:border-white/10 shadow-2xl z-[90] flex flex-col">
    <div class="h-1.5 w-full bg-gradient-to-r from-gray-300 via-accent to-gray-300 dark:from-gray-800 dark:via-accent dark:to-gray-800"></div>
    <div class="flex items-center justify-between p-6 border-b border-gray-100 dark:border-white/5">
      <img class="h-10 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار" />
      <img class="h-10 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار" />
      <button id="mobileNavClose" class="text-gray-500 hover:text-accent transition-colors" type="button" aria-label="إغلاق القائمة">
        <span class="material-symbols-outlined text-[28px]">close</span>
      </button>
    </div>
    <nav class="p-6 flex flex-col gap-4 font-bold text-lg flex-grow text-gray-700 dark:text-gray-300" aria-label="قائمة الجوال">
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/">الشجرة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/about">نبذة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/honor">قائمة السير الذاتية</a>
      <a class="px-4 py-3 rounded-lg text-accent bg-accent/5 border-r-2 border-accent" href="/news">أخبار العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/tree-pdf">مشجرة العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/support">الدعم</a>
    </nav>
    <div class="p-6 border-t border-gray-100 dark:border-white/5">
      <a href="/admin/login" class="flex items-center justify-center gap-2 py-3 bg-primary text-white dark:bg-white dark:text-primary rounded-lg hover:opacity-90 transition-colors font-bold" title="تسجيل الدخول">
        <span class="material-symbols-outlined">login</span>
      </a>
    </div>
  </aside>

  <header class="sticky top-0 z-50 w-full bg-white/95 dark:bg-[#050505]/95 backdrop-blur-md border-b border-gray-200 dark:border-white/10">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center h-20 md:h-24">
      <div class="flex items-center gap-4">
        <a href="/" class="block shrink-0">
          <img class="h-14 md:h-20 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار العائلة" />
          <img class="h-14 md:h-20 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار العائلة" />
        </a>
        <div class="h-10 w-px bg-gray-300 dark:bg-white/20"></div>
        <div class="flex items-center justify-center">
           <h1 class="text-2xl md:text-3xl font-display text-primary dark:text-accent font-bold leading-none tracking-wide pt-1">أخبار العائلة</h1>
        </div>
      </div>

      <nav class="hidden lg:flex gap-6 xl:gap-8 items-center font-sans font-bold text-sm tracking-wide uppercase text-gray-600 dark:text-gray-400">
        <a class="hover:text-accent transition-colors" href="/">الشجرة</a>
        <a class="hover:text-accent transition-colors" href="/about">نبذة</a>
        <a class="hover:text-accent transition-colors" href="/honor">قائمة السير الذاتية</a>
        <a class="text-primary dark:text-white border-b-2 border-accent pb-1" href="/news">أخبار العائلة</a>
        <a class="hover:text-accent transition-colors" href="/tree-pdf">مشجرة العائلة</a>
        <a class="hover:text-accent transition-colors" href="/support">الدعم</a>
      </nav>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent hover:bg-gray-50 dark:hover:bg-white/5 transition-all" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined dark:hidden">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:inline">light_mode</span>
        </button>

        <a href="/admin/login" class="hidden sm:flex p-2.5 rounded-full bg-primary text-white dark:bg-white dark:text-black hover:opacity-90 transition-all shadow-md flex items-center justify-center" title="تسجيل الدخول">
          <span class="material-symbols-outlined text-[22px]">login</span>
        </a>

        <button id="mobileNavBtn" data-open="false" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-primary dark:text-accent hover:bg-gray-200 dark:hover:bg-white/10 transition-colors" type="button" aria-label="فتح القائمة" aria-expanded="false">
          <span class="material-symbols-outlined text-[24px] ico-open">menu</span>
          <span class="material-symbols-outlined text-[24px] ico-close hidden">close</span>
        </button>
      </div>
    </div>
  </header>

  <main class="flex-grow relative">
    <%
      const img = post.image_url || post.person_photo_url || "/images/default.png";
      const currentShareUrl = typeof shareUrl !== "undefined" && shareUrl ? shareUrl : "";
      const encodedShareUrl = encodeURIComponent(currentShareUrl);
      const encodedTitle = encodeURIComponent(post.title || "");
      const likeCount = typeof likes !== "undefined" ? Number(likes || 0) : 0;
      const commentList = typeof comments !== "undefined" && comments ? comments : [];
    %>

    <section class="pt-14 pb-8 px-6 max-w-[90rem] mx-auto text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-islamic-pattern opacity-100 dark:opacity-30 pointer-events-none"></div>
      <img src="/assets/logo-dark.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[620px] opacity-[0.03] pointer-events-none hidden dark:block" alt="">
      <img src="/assets/logo-light.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[620px] opacity-[0.03] pointer-events-none block dark:hidden" alt="">

      <div class="w-px h-10 bg-accent mx-auto mb-5 relative z-10"></div>
      <a href="/news" class="inline-flex items-center gap-2 text-sm font-black text-primary dark:text-accent hover:text-accent transition-colors mb-5 relative z-10">
        <span class="material-symbols-outlined text-[18px] rotate-180">arrow_forward</span>
        العودة إلى أخبار العائلة
      </a>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display leading-tight mb-5 relative z-10 font-bold drop-shadow-sm dark:drop-shadow-none max-w-5xl mx-auto">
        <span class="text-primary dark:text-white"><%= post.title %></span>
      </h1>
      <div class="relative z-10 flex flex-wrap justify-center items-center gap-3 text-xs md:text-sm font-black text-gray-500 dark:text-gray-400">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/70 dark:bg-black/35 border border-gray-200 dark:border-white/10">
          <span class="material-symbols-outlined text-[16px] text-accent">calendar_month</span>
          <%= post.event_date || post.published_at || '' %>
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/70 dark:bg-black/35 border border-gray-200 dark:border-white/10">
          <span class="material-symbols-outlined text-[16px] text-accent">visibility</span>
          <%= Number(post.views_count || 0) %> مشاهدة
        </span>
        <% if (Number(post.is_pinned || 0) === 1) { %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-accent/15 text-primary dark:text-accent border border-accent/30">
            <span class="material-symbols-outlined text-[16px]">push_pin</span>
            خبر مهم
          </span>
        <% } %>
      </div>
    </section>

    <section class="px-6 md:px-8 pb-14 relative z-10">
      <div class="max-w-5xl mx-auto">
        <article class="article-shell">
          <div class="article-image-shell w-full">
            <img src="<%= img %>" alt="" class="article-image-blur" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
            <img src="<%= img %>" alt="<%= post.title || 'خبر' %>" class="article-image-main" loading="eager" decoding="async" onerror="this.src='/images/default.png'"/>
            <span class="article-date-badge">
              <span class="material-symbols-outlined text-[15px]">calendar_month</span>
              <span class="truncate"><%= post.event_date || post.published_at || 'خبر جديد' %></span>
            </span>
          </div>

          <div class="article-content">
            <div class="flex flex-wrap items-center gap-3 mb-7">
              <span class="news-category-pill">
                <span class="material-symbols-outlined text-[15px]">article</span>
                خبر عائلي
              </span>
              <% if (post.person_id) { %>
                <span class="news-category-pill">
                  <span class="material-symbols-outlined text-[15px]">person</span>
                  مرتبط بـ: <%= post.person_name || ('#' + post.person_id) %>
                </span>
              <% } %>
            </div>

            <% if (post.summary) { %>
              <p class="text-lg md:text-xl leading-9 text-gray-700 dark:text-gray-300 mb-7 border-r-4 border-accent pr-5 font-bold">
                <%= post.summary %>
              </p>
            <% } %>

            <div class="news-separator"></div>

            <div class="text-base md:text-lg leading-10 whitespace-pre-line text-gray-800 dark:text-gray-200 font-medium">
              <%= post.content || post.summary || '' %>
            </div>

            <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-5">
              <div class="soft-card rounded-3xl p-5">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                  <div>
                    <h3 class="font-display text-2xl font-bold text-primary dark:text-accent mb-1">التفاعل مع الخبر</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400 font-bold">يمكنك تسجيل إعجابك أو إضافة تعليق.</p>
                  </div>

                  <button id="likeBtn"
                          type="button"
                          class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-red-50 text-red-600 border border-red-100 font-black hover:bg-red-100 dark:bg-red-500/10 dark:text-red-300 dark:border-red-500/20 dark:hover:bg-red-500/15 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">favorite</span>
                    إعجاب
                    <span id="likeCount" class="inline-flex items-center justify-center min-w-7 h-7 rounded-full bg-white dark:bg-black/20 px-2">
                      <%= likeCount %>
                    </span>
                  </button>
                </div>
              </div>

              <div class="soft-card rounded-3xl p-5">
                <h3 class="font-display text-2xl font-bold text-primary dark:text-accent mb-3">مشاركة الخبر</h3>
                <div class="flex flex-wrap gap-2">
                  <a href="https://wa.me/?text=<%= encodedTitle %>%20<%= encodedShareUrl %>"
                     target="_blank"
                     rel="noopener"
                     class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-emerald-600 text-white font-bold hover:bg-emerald-700 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">share</span>
                    واتساب
                  </a>

                  <a href="https://twitter.com/intent/tweet?text=<%= encodedTitle %>&url=<%= encodedShareUrl %>"
                     target="_blank"
                     rel="noopener"
                     class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-sky-600 text-white font-bold hover:bg-sky-700 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">share</span>
                    تويتر
                  </a>

                  <button id="copyLinkBtn"
                          type="button"
                          data-url="<%= currentShareUrl %>"
                          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-gray-200 dark:border-white/10 font-bold hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">content_copy</span>
                    نسخ الرابط
                  </button>
                </div>

                <p id="copyMsg" class="hidden mt-3 text-sm font-bold text-emerald-600 dark:text-emerald-300">
                  تم نسخ رابط الخبر.
                </p>
              </div>
            </div>

            <div class="mt-12 pt-8 border-t border-gray-200 dark:border-white/10">
              <div class="flex items-center gap-3 mb-5">
                <span class="w-11 h-11 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent flex items-center justify-center">
                  <span class="material-symbols-outlined">forum</span>
                </span>
                <h3 class="text-3xl font-display font-bold text-primary dark:text-white">التعليقات</h3>
              </div>

              <form method="post"
                    action="/news/<%= post.id %>/comment"
                    class="soft-card rounded-3xl p-4 sm:p-6 mb-7">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                  <input name="name"
                         required
                         maxlength="80"
                         placeholder="اسمك"
                         class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-white/80 dark:bg-black/35 text-sm font-bold focus:outline-none focus:ring-2 focus:ring-accent/30"/>

                  <input value="<%= post.title || '' %>"
                         disabled
                         class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-black/25 text-sm font-bold text-gray-500 dark:text-gray-400"/>
                </div>

                <textarea name="content"
                          required
                          maxlength="1000"
                          rows="4"
                          placeholder="اكتب تعليقك..."
                          class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-white/80 dark:bg-black/35 text-sm font-bold leading-relaxed focus:outline-none focus:ring-2 focus:ring-accent/30"></textarea>

                <div class="mt-3 flex justify-end">
                  <button type="submit"
                          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white dark:bg-white dark:text-primary font-black hover:opacity-90 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">send</span>
                    إرسال التعليق
                  </button>
                </div>
              </form>

              <% if (!commentList || commentList.length === 0) { %>
                <div class="soft-card rounded-3xl p-7 text-center text-gray-500 dark:text-gray-400 font-bold">
                  <span class="material-symbols-outlined text-4xl text-accent mb-2">chat_bubble</span>
                  <p>لا توجد تعليقات بعد. كن أول من يعلّق.</p>
                </div>
              <% } else { %>
                <div class="space-y-3">
                  <% commentList.forEach(function(c) { %>
                    <div class="soft-card rounded-3xl p-5">
                      <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                        <div class="font-black text-primary dark:text-accent inline-flex items-center gap-2">
                          <span class="material-symbols-outlined text-[20px]">account_circle</span>
                          <%= c.name || 'زائر' %>
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 font-bold">
                          <%= c.created_at || '' %>
                        </div>
                      </div>
                      <p class="text-sm sm:text-base leading-relaxed whitespace-pre-line text-gray-700 dark:text-gray-300 font-medium">
                        <%= c.content || '' %>
                      </p>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <div class="mt-10 pt-6 border-t border-gray-200 dark:border-white/10 flex flex-col sm:flex-row justify-between gap-3">
              <a href="/news" class="inline-flex justify-center items-center px-6 py-3 rounded-xl bg-primary text-white dark:bg-white dark:text-primary font-black hover:opacity-90 transition-colors">
                العودة للأخبار
              </a>

              <a href="/" class="inline-flex justify-center items-center px-6 py-3 rounded-xl border border-gray-200 dark:border-white/10 font-black hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                العودة للشجرة
              </a>
            </div>
          </div>
        </article>

        <% if (typeof relatedPosts !== "undefined" && relatedPosts && relatedPosts.length) { %>
          <section class="mt-12">
            <div class="flex items-center justify-between gap-3 mb-5">
              <h2 class="text-3xl font-display font-bold text-primary dark:text-white">أخبار مشابهة</h2>
              <a href="/news" class="text-sm font-black text-primary dark:text-accent hover:text-accent transition-colors">كل الأخبار</a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              <% relatedPosts.forEach(function(p) {
                const relImg = p.image_url || p.person_photo_url || "/images/default.png";
              %>
                <article class="related-card group">
                  <a href="/news/<%= p.id %>" class="block h-48 bg-gray-100 dark:bg-black/20 overflow-hidden">
                    <img src="<%= relImg %>"
                         alt="<%= p.title || 'خبر' %>"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                         loading="lazy"
                         decoding="async"
                         onerror="this.src='/images/default.png'">
                  </a>

                  <div class="p-5">
                    <div class="text-xs text-gray-500 dark:text-gray-400 mb-2 font-bold inline-flex items-center gap-1">
                      <span class="material-symbols-outlined text-[15px] text-accent">calendar_month</span>
                      <%= p.event_date || p.published_at || '' %>
                    </div>

                    <h3 class="font-display text-xl font-bold text-primary dark:text-white line-clamp-2 mb-2 leading-tight">
                      <a href="/news/<%= p.id %>" class="hover:text-accent dark:hover:text-accent transition-colors">
                        <%= p.title %>
                      </a>
                    </h3>

                    <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 leading-relaxed">
                      <%= p.summary || p.content || '' %>
                    </p>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% } %>
      </div>
    </section>
  </main>

  <footer class="bg-background-light dark:bg-bg-charcoal border-t border-gray-200 dark:border-white/10 mt-auto py-8 relative z-10">
    <div class="max-w-[90rem] mx-auto px-6 text-center flex flex-col items-center gap-3">
      <p class="text-[11px] font-sans font-bold text-gray-500 uppercase tracking-[0.1em]">
        © ٢٠٢٦ وقف عائلة خاشقجي. جميع الحقوق محفوظة.
      </p>
    </div>
  </footer>

  <script>
    (function () {
      const btn = document.getElementById("themeBtn");
      function applyTheme(next) {
        document.documentElement.setAttribute("data-theme", next);
        document.documentElement.classList.toggle("dark", next === "dark");
        localStorage.setItem("theme", next);
      }
      btn?.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme") || "dark";
        applyTheme(current === "dark" ? "light" : "dark");
      });
      applyTheme(localStorage.getItem("theme") || "dark");
    })();

    (function(){
      const likeBtn = document.getElementById("likeBtn");
      const likeCount = document.getElementById("likeCount");

      likeBtn?.addEventListener("click", async () => {
        try {
          likeBtn.disabled = true;

          const res = await fetch("/news/<%= post.id %>/like", {
            method: "POST",
            headers: { "Accept": "application/json" }
          });

          const data = await res.json();

          if (data && data.ok && likeCount) {
            likeCount.textContent = data.count;
          }
        } catch (e) {
          console.error(e);
        } finally {
          setTimeout(() => {
            likeBtn.disabled = false;
          }, 600);
        }
      });
    })();

    (function(){
      const copyBtn = document.getElementById("copyLinkBtn");
      const copyMsg = document.getElementById("copyMsg");

      copyBtn?.addEventListener("click", async () => {
        const url = copyBtn.getAttribute("data-url") || window.location.href;

        try {
          await navigator.clipboard.writeText(url);
          copyMsg?.classList.remove("hidden");
          setTimeout(() => copyMsg?.classList.add("hidden"), 2500);
        } catch (e) {
          window.prompt("انسخ الرابط:", url);
        }
      });
    })();

    (function mobileNavInit(){
      const btn = document.getElementById("mobileNavBtn");
      const navDrawer = document.getElementById("mobileNavDrawer");
      const overlay = document.getElementById("mobileNavOverlay");
      const closeBtn = document.getElementById("mobileNavClose");

      function setOpenState(isOpen){
        btn?.setAttribute("data-open", isOpen ? "true" : "false");
        btn?.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }

      function openNav(){
        overlay?.classList.remove("hidden");
        navDrawer?.classList.add("isOpen");
        setOpenState(true);
      }
      function closeNav(){
        navDrawer?.classList.remove("isOpen");
        overlay?.classList.add("hidden");
        setOpenState(false);
      }

      btn?.addEventListener("click", () => {
        const open = btn.getAttribute("data-open") === "true";
        open ? closeNav() : openNav();
      });

      closeBtn?.addEventListener("click", closeNav);
      overlay?.addEventListener("click", closeNav);
      navDrawer?.querySelectorAll("a").forEach(a => a.addEventListener("click", closeNav));
      window.addEventListener("keydown", (e) => { if (e.key === "Escape") closeNav(); });

      setOpenState(false);
    })();
  </script>

</body>
</html>
