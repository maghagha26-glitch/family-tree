<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>لوحة الإدارة - إدارة الأفراد</title>

  <script src="/theme.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",     /* البنفسجي الملكي */
            primaryDark: "#00361A", 
            accent: "#E5B869",      /* الذهب السائل */
            "bg-light": "#F5F3F7",  /* خلفية فاتحة دافئة */
            "bg-dark": "#050505",   /* خلفية داكنة جداً بلمحة بنفسجية */
            "card-light": "rgba(255, 255, 255, 0.8)",
            "card-dark": "rgba(15, 12, 25, 0.8)",
            "border-light": "rgba(0, 90, 43, 0.1)",
            "border-dark": "rgba(229, 184, 105, 0.1)",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .glass-panel { @apply backdrop-blur-2xl shadow-xl; }
    }
  </style>

  <style>
    /* تخصيص شريط التمرير */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #005A2B; border-radius: 10px; }
    html.dark ::-webkit-scrollbar-thumb { background: #E5B869; }

    /* حقل البحث الذكي */
    .search-input { transition: all 0.3s ease; }
    .search-input:focus {
      box-shadow: 0 0 20px rgba(0, 90, 43, 0.15);
      border-color: #005A2B;
      transform: translateY(-1px);
    }
    html.dark .search-input:focus {
      box-shadow: 0 0 20px rgba(229, 184, 105, 0.15);
      border-color: #E5B869;
    }

    /* صفوف الجدول الديناميكية (Floating Rows) */
    .interactive-row {
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      border-right: 3px solid transparent;
      border-radius: 12px;
    }
    .interactive-row:hover {
      background: #ffffff !important;
      border-right-color: #005A2B;
      transform: translateX(-4px) scale(1.01);
      box-shadow: 0 10px 30px rgba(0, 90, 43, 0.1);
      z-index: 10;
      position: relative;
    }
    html.dark .interactive-row:hover {
      background: #1A1525 !important;
      border-right-color: #E5B869;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
    }
    .interactive-row:hover td { border-bottom-color: transparent !important; }

    /* شبكة العائلة التفاعلية في الخلفية */
    #nexusCanvas {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0; pointer-events: auto; /* لاستقبال حركة الماوس */
    }

    /* إعدادات أيقونات المظهر */
    html.dark .dark-toggle-icon-moon { display: none; }
    html:not(.dark) .dark-toggle-icon-sun { display: none; }

    /* Mobile Nav */
    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer { transform: translateX(110%); transition: transform .4s cubic-bezier(0.16, 1, 0.3, 1); }
    #mobileNavDrawer.isOpen { transform: translateX(0); }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");
    })();
  </script>

  <style id="solid-color-final-fix">
    .bg-primary,
    a.bg-primary,
    button.bg-primary {
      background-color: #005A2B !important;
      background-image: none !important;
    }

    .dark .dark\:bg-accent,
    html.dark .dark\:bg-accent {
      background-color: #E5B869 !important;
      background-image: none !important;
    }

    [class*="bg-gradient"] {
      background-image: none !important;
    }

    .solid-admin-action {
      background-color: #005A2B !important;
      background-image: none !important;
    }

    html.dark .solid-admin-action {
      background-color: #E5B869 !important;
      color: #050505 !important;
    }
  </style>

</head>

<body class="bg-bg-light dark:bg-bg-dark text-gray-800 dark:text-gray-200 font-sans h-screen flex overflow-hidden selection:bg-accent selection:text-primaryDark">

  <canvas id="nexusCanvas"></canvas>
  <div class="fixed inset-0 bg-gradient-to-b from-white/40 to-white/80 dark:from-black/40 dark:to-[#050505]/90 pointer-events-none z-[1]"></div>

  <aside class="relative z-20 hidden lg:flex flex-col w-[280px] h-[calc(100vh-2rem)] my-4 mx-4 bg-card-light dark:bg-card-dark glass-panel rounded-3xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
    
    <div class="flex items-center gap-3 p-6 border-b border-border-light dark:border-border-dark shrink-0">
      <div class="w-12 h-12 flex items-center justify-center rounded-2xl bg-primary dark:bg-accent text-white dark:text-black shadow-lg">
        <span class="material-symbols-outlined text-[28px]">shield_person</span>
      </div>
      <div>
        <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
        <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة المركزية</p>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-6">
      
      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">البيانات الرئيسية</p>

        <a href="/admin" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent font-bold text-sm border border-primary/20 dark:border-accent/20 transition-all relative overflow-hidden shadow-sm">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-6 rounded-l-full bg-primary dark:bg-accent shadow-[0_0_10px_rgba(229,184,105,0.8)]"></div>
          <span class="material-symbols-outlined text-[22px]">group</span>
          إدارة الأفراد
        </a>

        <a href="/admin/pages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">history_edu</span> إدارة الصفحات
        </a>

        <a href="/admin/honor" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">workspace_premium</span> السير الذاتية
        </a>

        <a href="/admin/news" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">newspaper</span> الأخبار والمناسبات
        </a>
      </div>

      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">النظام والموقع</p>
        
        <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">mail</span> رسائل الدعم
        </a>
        
        <a href="/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">account_tree</span> عرض الشجرة
        </a>
      </div>
    </nav>

    <div class="p-4 border-t border-border-light dark:border-border-dark shrink-0 m-2 rounded-2xl bg-white/50 dark:bg-black/30">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-cover bg-center border border-gray-200 dark:border-white/10 shadow-sm" style="background-image:url('/assets/default-avatar.png'); background-color: #ddd;"></div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-gray-900 dark:text-white truncate"><%= admin?.username || "مدير النظام" %></p>
          <p class="text-[10px] text-primary dark:text-accent uppercase tracking-widest mt-0.5 font-bold">Admin</p>
        </div>
        <form method="post" action="/admin/logout" class="m-0">
          <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="تسجيل خروج">
            <span class="material-symbols-outlined text-[18px]">logout</span>
          </button>
        </form>
      </div>
    </div>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 h-full relative z-10">
    
    <header class="flex items-center justify-between p-4 lg:p-8 shrink-0">
      
      <div class="flex items-center gap-3">
        <button id="mobileNavBtn" class="lg:hidden flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-primary dark:text-accent shadow-sm" type="button">
          <span class="material-symbols-outlined text-[24px]">menu</span>
        </button>

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary dark:text-white tracking-tight leading-none mb-1.5">إدارة الأفراد</h2>
          <div class="flex items-center gap-1.5 text-gray-500 text-[11px] font-bold uppercase tracking-widest">
            <span>لوحة الإدارة</span>
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            <span class="text-accent">السجل الشامل</span>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-gray-600 dark:text-accent shadow-sm hover:-translate-y-1 transition-transform" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined text-[22px] dark-toggle-icon-moon">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:block text-[24px]">light_mode</span>
        </button>

        <a href="/admin/person/new" class="flex items-center gap-2 px-6 h-12 rounded-2xl font-bold text-sm bg-primary dark:bg-accent text-white dark:text-black shadow-[0_5px_20px_rgba(58,46,124,0.4)] dark:shadow-[0_5px_20px_rgba(229,184,105,0.20)] hover:-translate-y-1 transition-transform">
          <span class="material-symbols-outlined text-[22px]">person_add</span>
          <span class="hidden sm:inline">إضافة شخص جديد</span>
        </a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-4 lg:px-8 pb-12">
      <div class="max-w-[100rem] mx-auto space-y-8">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
          
          <div class="lg:col-span-2 bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-2 pl-4 flex items-center shadow-sm">
            <span class="material-symbols-outlined text-gray-400 mr-4 ml-2 text-[26px]">search</span>
            <input id="searchInput" type="text" placeholder="ابحث بالاسم، الأب، الزوج، الـ ID..." 
              class="search-input w-full h-14 bg-transparent border-none text-gray-900 dark:text-white placeholder-gray-400 font-sans font-bold text-base focus:ring-0 px-2"/>
          </div>

          <div class="bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 flex items-center gap-4 shadow-sm group">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 dark:bg-accent/10 flex items-center justify-center text-primary dark:text-accent group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-[28px]">groups</span>
            </div>
            <div>
              <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-0.5">إجمالي الأفراد</p>
              <p class="text-3xl font-black text-primary dark:text-white leading-none"><%= persons?.length || 0 %></p>
            </div>
          </div>

          <a href="/admin/person-stats" class="bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-5 flex items-center gap-4 shadow-sm group hover:border-primary dark:hover:border-accent transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-red-50 dark:bg-red-500/10 flex items-center justify-center text-red-500 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-[28px]">content_copy</span>
            </div>
            <div>
              <p class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-0.5">أسماء متكررة</p>
              <p class="text-3xl font-black text-red-600 dark:text-red-400 leading-none"><%= stats?.repeatedNames?.length || 0 %></p>
            </div>
            <span class="material-symbols-outlined mr-auto text-gray-300 dark:text-gray-600 rtl:rotate-180">arrow_forward_ios</span>
          </a>

        </div>

        <% if (stats?.repeatedNames && stats.repeatedNames.length) { %>
          <section class="bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark rounded-3xl p-6 shadow-sm">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-red-500 text-[22px]">warning</span>
              <h3 class="font-bold text-gray-900 dark:text-white text-base">قائمة الأسماء المكررة للتحقق</h3>
            </div>
            
            <div class="flex flex-wrap gap-3">
              <% stats.repeatedNames.forEach(function(item) { %>
                <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-xl bg-white dark:bg-[#111] border border-gray-200 dark:border-white/10 shadow-sm cursor-default hover:-translate-y-1 transition-transform">
                  <span class="font-bold text-sm text-gray-800 dark:text-gray-200"><%= item.name %></span>
                  <span class="flex items-center justify-center min-w-[24px] h-6 rounded-lg bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-400 text-xs font-black">
                    <%= item.count %>
                  </span>
                </div>
              <% }) %>
            </div>
          </section>
        <% } %>

        <section class="bg-card-light dark:bg-card-dark glass-panel rounded-3xl shadow-sm border border-border-light dark:border-border-dark overflow-hidden">
          <div class="overflow-x-auto custom-scrollbar p-2">
            <table class="w-full min-w-[1200px] text-sm text-right border-separate border-spacing-y-2">
              <thead class="bg-transparent">
                <tr>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-20">الصورة</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] min-w-[220px]">الاسم والرقم</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-24">النوع</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-28">الحالة</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] min-w-[150px]">الأب</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] min-w-[150px]">الأم</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] min-w-[150px]">الشريك</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px]">التواريخ</th>
                  <th class="py-3 px-6 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-32 text-center">الإجراءات</th>
                </tr>
              </thead>

              <tbody id="peopleTableBody">
                <% for (let i = 0; i < persons.length; i++) {
                     const p = persons[i];
                     const photo = (p.photo_url && String(p.photo_url).trim()) ? p.photo_url : "";
                     
                     let genderLabel = "-";
                     let isMale = false;
                     if (p.gender === "male" || p.gender === "ذكر") { genderLabel = "ذكر"; isMale = true; }
                     else if (p.gender === "female" || p.gender === "أنثى" || p.gender === "انثى") { genderLabel = "أنثى"; }

                     const isDeceased = Number(p.is_deceased || 0) === 1;
                     const avatarBorder = isMale ? "border-primary/50 dark:border-primary" : "border-accent/50 dark:border-accent";
                     const avatarBg = isMale ? "bg-primary/10 text-primary" : "bg-accent/10 text-[#cfae61] dark:text-accent";
                %>
                  <tr class="interactive-row group bg-gray-50/50 dark:bg-white/5 border border-transparent border-b-gray-100 dark:border-b-white/5">
                    
                    <td class="py-3 px-6 rounded-r-xl">
                      <div class="relative w-12 h-12 rounded-xl border-2 <%= avatarBorder %> overflow-hidden flex items-center justify-center <%= photo ? '' : avatarBg %> shadow-sm bg-white dark:bg-black">
                        <% if (photo) { %>
                          <img src="<%= photo %>" alt="" class="w-full h-full object-cover">
                        <% } else { %>
                          <span class="material-symbols-outlined text-[24px]">person</span>
                        <% } %>
                        <% if (isDeceased) { %>
                          <div class="absolute inset-0 bg-black/60 flex items-center justify-center backdrop-blur-[1px]">
                            <div class="w-full h-[2px] bg-red-500 rotate-45"></div>
                          </div>
                        <% } %>
                      </div>
                    </td>

                    <td class="py-3 px-6">
                      <div class="flex flex-col">
                        <span class="font-bold text-base text-gray-900 dark:text-white person-name group-hover:text-primary dark:group-hover:text-accent transition-colors"><%= p.name %></span>
                        <span class="text-[10px] font-bold text-gray-400 dark:text-accent/60 uppercase tracking-widest mt-0.5 person-id">ID: <%= p.id %></span>
                      </div>
                    </td>

                    <td class="py-3 px-6">
                      <span class="inline-flex px-3 py-1 rounded-lg text-[11px] font-bold <%= isMale ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-green-400' : 'bg-accent/10 text-[#cfae61] dark:bg-accent/20 dark:text-accent' %> person-gender">
                        <%= genderLabel %>
                      </span>
                    </td>

                    <td class="py-3 px-6">
                      <% if (isDeceased) { %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-200 dark:bg-white/10 text-gray-700 dark:text-gray-300 font-bold text-[11px] person-status">
                          <span class="material-symbols-outlined text-[14px]">history_toggle_off</span> متوفى
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-100 dark:bg-primary/20 text-green-800 dark:text-green-400 font-bold text-[11px] person-status">
                          <span class="material-symbols-outlined text-[14px]">favorite</span> حي
                        </span>
                      <% } %>
                    </td>

                    <td class="py-3 px-6 text-gray-700 dark:text-gray-300 font-medium text-sm person-father"><%= p.father_name || "-" %></td>
                    <td class="py-3 px-6 text-gray-700 dark:text-gray-300 font-medium text-sm person-mother"><%= p.mother_name || "-" %></td>
                    <td class="py-3 px-6 text-gray-600 dark:text-gray-400 font-medium text-sm person-spouses"><%= p.spouses_text || "-" %></td>

                    <td class="py-3 px-6">
                      <div class="flex flex-col gap-1.5 text-[11px] font-bold text-gray-500 dark:text-gray-400">
                        <div class="flex items-center gap-1.5 person-birth">
                          <span class="material-symbols-outlined text-[14px] text-primary dark:text-accent">child_care</span>
                          <%= p.birth_date || "غير محدد" %>
                        </div>
                        <% if (isDeceased) { %>
                          <div class="flex items-center gap-1.5 person-death">
                            <span class="material-symbols-outlined text-[14px] text-gray-400">psychology</span>
                            <%= p.death_date || "غير محدد" %>
                          </div>
                        <% } %>
                      </div>
                    </td>

                    <td class="py-3 px-6 text-center rounded-l-xl">
                      <div class="flex items-center justify-center gap-2 opacity-100 lg:opacity-0 group-hover:opacity-100 transition-opacity">
                        
                        <a href="/admin/person/<%= p.id %>/edit" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white dark:bg-[#111] border border-gray-200 hover:border-primary text-gray-600 hover:text-primary dark:border-white/10 dark:text-gray-400 dark:hover:border-accent dark:hover:text-accent transition-all shadow-sm hover:scale-105" title="تعديل">
                          <span class="material-symbols-outlined text-[18px]">edit</span>
                        </a>

                        <form method="post" action="/admin/person/<%= p.id %>/delete" class="m-0" onsubmit="return confirm('هل أنت متأكد من حذف هذا السجل نهائياً؟');">
                          <button type="submit" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white dark:bg-[#111] border border-gray-200 hover:border-red-500 text-gray-600 hover:text-white hover:bg-red-500 dark:border-white/10 dark:text-gray-400 dark:hover:border-red-500/50 dark:hover:text-red-400 transition-all shadow-sm hover:scale-105" title="حذف">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                          </button>
                        </form>

                      </div>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

      </div>
    </div>
  </main>
</div>

<aside id="mobileNavDrawer" class="fixed top-0 right-0 h-full w-[320px] max-w-[85vw] bg-card-light dark:bg-card-dark glass-panel border-l border-border-light dark:border-border-dark z-[90] flex flex-col">
  <div class="h-1.5 w-full bg-primary"></div>
  <div class="flex items-center justify-between p-6 border-b border-border-light dark:border-border-dark shrink-0">
    <div>
      <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
      <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة</p>
    </div>
    <button id="mobileNavClose" class="w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-500 hover:text-primary dark:hover:text-accent transition-colors" type="button">
      <span class="material-symbols-outlined text-[24px]">close</span>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-3 text-sm font-bold text-gray-700 dark:text-gray-300">
    <a href="/admin" class="flex items-center gap-3 px-4 py-4 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent transition-colors border border-primary/20 dark:border-accent/20"><span class="material-symbols-outlined">group</span> إدارة الأفراد</a>
    <a href="/admin/pages" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">history_edu</span> إدارة الصفحات</a>
    <a href="/admin/honor" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">workspace_premium</span> السير الذاتية</a>
    <a href="/admin/news" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">newspaper</span> الأخبار</a>
    <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">mail</span> رسائل الدعم</a>
    <div class="my-4 border-t border-border-light dark:border-border-dark"></div>
    <a href="/" class="flex items-center gap-3 px-4 py-4 rounded-2xl border border-transparent hover:bg-gray-50 dark:hover:bg-white/5 transition-colors"><span class="material-symbols-outlined text-gray-400">account_tree</span> العودة للموقع</a>
    
    <form method="post" action="/admin/logout" class="m-0 mt-4">
      <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-4 rounded-2xl border border-red-200 dark:border-red-900/30 text-red-600 dark:text-red-400 bg-red-50/50 dark:bg-red-500/10 hover:bg-red-50 transition-colors">
        <span class="material-symbols-outlined">logout</span> تسجيل خروج
      </button>
    </form>
  </nav>
</aside>

<div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>

<script>
  // Theme Toggle (Instant & High Performance)
  (function () {
    const btn = document.getElementById("themeBtn");
    function setTheme(next) {
      document.documentElement.setAttribute("data-theme", next);
      document.documentElement.classList.toggle("dark", next === "dark");
      localStorage.setItem("theme", next);
      if(window.initNexus) window.initNexus(); // تحديث ألوان الشبكة الخلفية
    }
    btn?.addEventListener("click", () => {
      const cur = document.documentElement.getAttribute("data-theme") || "dark";
      setTheme(cur === "dark" ? "light" : "dark");
    });
  })();

  // Instant Live Search
  (function(){
    const input = document.getElementById("searchInput");
    const tbody = document.getElementById("peopleTableBody");
    if(!input || !tbody) return;

    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      const rows = tbody.querySelectorAll("tr");
      rows.forEach(tr => {
        const name = (tr.querySelector(".person-name")?.textContent || "").toLowerCase();
        const father = (tr.querySelector(".person-father")?.textContent || "").toLowerCase();
        const mother = (tr.querySelector(".person-mother")?.textContent || "").toLowerCase();
        const spouses = (tr.querySelector(".person-spouses")?.textContent || "").toLowerCase();
        const idtxt = (tr.querySelector(".person-id")?.textContent || "").toLowerCase();

        const hay = [name, father, mother, spouses, idtxt].join(" ");
        tr.style.display = (!q || hay.includes(q)) ? "" : "none";
      });
    });
  })();

  // Mobile Drawer
  (function mobileNavInit(){
    const btn = document.getElementById("mobileNavBtn");
    const navDrawer = document.getElementById("mobileNavDrawer");
    const overlay = document.getElementById("mobileNavOverlay");
    const closeBtn = document.getElementById("mobileNavClose");

    function toggleNav() {
      navDrawer?.classList.toggle("isOpen");
      overlay?.classList.toggle("hidden");
    }
    
    btn?.addEventListener("click", toggleNav);
    closeBtn?.addEventListener("click", toggleNav);
    overlay?.addEventListener("click", toggleNav);
  })();

  // ==========================================
  // سكريبت "الشبكة التفاعلية الممتعة" في الخلفية (The Family Nexus)
  // يمثل ترابط العائلة بأسلوب تقني أنيق جداً وخفيف على الأداء
  // ==========================================
  (function() {
    const canvas = document.getElementById('nexusCanvas');
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    
    let width, height;
    let particles = [];
    // عدد العقد معقول للحفاظ على سرعة المتصفح
    const numParticles = window.innerWidth > 1024 ? 130 : 70; 
    
    let mouseX = -1000;
    let mouseY = -1000;

    let dotColor, lineColor, connectionColor;

    window.initNexus = function() {
      const isDark = document.documentElement.classList.contains('dark');
      // ألوان الشبكة بناءً على الهوية البصرية الملكية
      dotColor = isDark ? 'rgba(229, 184, 105, 0.55)' : 'rgba(0, 90, 43, 0.32)'; // ذهبي أو بنفسجي
      lineColor = isDark ? 'rgba(229, 184, 105, 0.16)' : 'rgba(0, 90, 43, 0.09)';
      connectionColor = isDark ? '229, 184, 105' : '58, 46, 124'; 
    };

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }

    function initParticles() {
      particles = [];
      for (let i = 0; i < numParticles; i++) {
        particles.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
          radius: Math.random() * 2.8 + 1.2
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, width, height);

      // تحديث وحركة النقاط
      for (let i = 0; i < numParticles; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;

        // ارتداد من الحواف
        if (p.x < 0 || p.x > width) p.vx *= -1;
        if (p.y < 0 || p.y > height) p.vy *= -1;

        // رسم النقطة
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = dotColor;
        ctx.fill();

        // التفاعل مع الماوس (السحر هنا)
        const dxMouse = mouseX - p.x;
        const dyMouse = mouseY - p.y;
        const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);

        if (distMouse < 230) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(mouseX, mouseY);
          const opacity = 0.6 * (1 - distMouse / 230);
          ctx.strokeStyle = `rgba(${connectionColor}, ${opacity})`;
          ctx.lineWidth = 1;
          ctx.stroke();
          
          // جاذبية خفيفة للماوس
          p.x += dxMouse * 0.014;
          p.y += dyMouse * 0.014;
        }

        // رسم الخطوط بين النقاط وبعضها
        for (let j = i + 1; j < numParticles; j++) {
          const p2 = particles[j];
          const dx = p.x - p2.x;
          const dy = p.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 165) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = lineColor;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      requestAnimationFrame(draw);
    }

    window.addEventListener('resize', () => { resize(); initParticles(); });
    window.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
    window.addEventListener('mouseout', () => { mouseX = -1000; mouseY = -1000; });

    window.initNexus();
    resize();
    initParticles();
    draw();
  })();
</script>
</body>
</html>