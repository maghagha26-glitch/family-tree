<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title><%= mode === "new" ? "إضافة شخص" : "تعديل شخص" %> - لوحة الإدارة</title>

  <script src="/theme.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",     /* البنفسجي الملكي */
            primaryDark: "#00361A", 
            accent: "#E5B869",      /* الذهب السائل */
            "bg-light": "#F5F3F7",  /* خلفية فاتحة دافئة */
            "bg-dark": "#050505",   /* خلفية داكنة جداً بلمحة بنفسجية */
            "card-light": "rgba(255, 255, 255, 0.8)",
            "card-dark": "rgba(15, 12, 25, 0.8)",
            "border-light": "rgba(0, 90, 43, 0.1)",
            "border-dark": "rgba(229, 184, 105, 0.1)",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .glass-panel { @apply backdrop-blur-2xl shadow-xl; }
    }
  </style>

  <style>
    /* تخصيص شريط التمرير */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #005A2B; border-radius: 10px; }
    html.dark ::-webkit-scrollbar-thumb { background: #E5B869; }

    /* حقول الإدخال */
    .form-input { transition: all 0.3s ease; }
    .form-input:focus {
      box-shadow: 0 0 20px rgba(0, 90, 43, 0.15);
      border-color: #005A2B !important;
      transform: translateY(-1px);
    }
    html.dark .form-input:focus {
      box-shadow: 0 0 20px rgba(229, 184, 105, 0.15);
      border-color: #E5B869 !important;
    }

    /* شبكة العائلة التفاعلية في الخلفية */
    #nexusCanvas {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0; pointer-events: auto;
    }

    /* إعدادات أيقونات المظهر */
    html.dark .dark-toggle-icon-moon { display: none; }
    html:not(.dark) .dark-toggle-icon-sun { display: none; }

    /* Mobile Nav */
    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer { transform: translateX(110%); transition: transform .4s cubic-bezier(0.16, 1, 0.3, 1); }
    #mobileNavDrawer.isOpen { transform: translateX(0); }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");
    })();
  </script>

  <style id="solid-color-final-fix">
    .bg-primary, a.bg-primary, button.bg-primary { background-color: #005A2B !important; background-image: none !important; }
    .dark .dark\:bg-accent, html.dark .dark\:bg-accent { background-color: #E5B869 !important; background-image: none !important; }
    [class*="bg-gradient"] { background-image: none !important; }
    .solid-admin-action { background-color: #005A2B !important; background-image: none !important; }
    html.dark .solid-admin-action { background-color: #E5B869 !important; color: #050505 !important; }
  </style>
</head>

<body class="bg-bg-light dark:bg-bg-dark text-gray-800 dark:text-gray-200 font-sans h-screen flex overflow-hidden selection:bg-accent selection:text-primaryDark">

  <canvas id="nexusCanvas"></canvas>
  <div class="fixed inset-0 bg-gradient-to-b from-white/40 to-white/80 dark:from-black/40 dark:to-[#050505]/90 pointer-events-none z-[1]"></div>

  <aside class="relative z-20 hidden lg:flex flex-col w-[280px] h-[calc(100vh-2rem)] my-4 mx-4 bg-card-light dark:bg-card-dark glass-panel rounded-3xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
    <div class="flex items-center gap-3 p-6 border-b border-border-light dark:border-border-dark shrink-0">
      <div class="w-12 h-12 flex items-center justify-center rounded-2xl bg-primary dark:bg-accent text-white dark:text-black shadow-lg">
        <span class="material-symbols-outlined text-[28px]">shield_person</span>
      </div>
      <div>
        <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
        <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة المركزية</p>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-6">
      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">البيانات الرئيسية</p>
        <a href="/admin" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent font-bold text-sm border border-primary/20 dark:border-accent/20 transition-all relative overflow-hidden shadow-sm">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-6 rounded-l-full bg-primary dark:bg-accent shadow-[0_0_10px_rgba(229,184,105,0.8)]"></div>
          <span class="material-symbols-outlined text-[22px]">group</span> إدارة الأفراد
        </a>
        <a href="/admin/pages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">history_edu</span> إدارة الصفحات
        </a>
        <a href="/admin/honor" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">workspace_premium</span> السير الذاتية
        </a>
        <a href="/admin/news" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">newspaper</span> الأخبار والمناسبات
        </a>
      </div>

      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">النظام والموقع</p>
        <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">mail</span> رسائل الدعم
        </a>
        <a href="/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">account_tree</span> عرض الشجرة
        </a>
      </div>
    </nav>

    <div class="p-4 border-t border-border-light dark:border-border-dark shrink-0 m-2 rounded-2xl bg-white/50 dark:bg-black/30">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-cover bg-center border border-gray-200 dark:border-white/10 shadow-sm" style="background-image:url('/assets/default-avatar.png'); background-color: #ddd;"></div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-gray-900 dark:text-white truncate"><%= locals.admin?.username || "مدير النظام" %></p>
          <p class="text-[10px] text-primary dark:text-accent uppercase tracking-widest mt-0.5 font-bold">Admin</p>
        </div>
        <form method="post" action="/admin/logout" class="m-0">
          <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="تسجيل خروج">
            <span class="material-symbols-outlined text-[18px]">logout</span>
          </button>
        </form>
      </div>
    </div>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 h-full relative z-10">
    
    <header class="flex items-center justify-between p-4 lg:p-8 shrink-0">
      <div class="flex items-center gap-3">
        <button id="mobileNavBtn" class="lg:hidden flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-primary dark:text-accent shadow-sm" type="button">
          <span class="material-symbols-outlined text-[24px]">menu</span>
        </button>

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary dark:text-white tracking-tight leading-none mb-1.5">
            <%= mode === "new" ? "إضافة شخص" : "تعديل شخص" %>
          </h2>
          <div class="flex items-center gap-1.5 text-gray-500 text-[11px] font-bold uppercase tracking-widest">
            <span>لوحة الإدارة</span>
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            <a href="/admin" class="hover:text-primary dark:hover:text-accent transition-colors">إدارة الأفراد</a>
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            <span class="text-accent"><%= mode === "new" ? "إضافة" : "تعديل" %></span>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-gray-600 dark:text-accent shadow-sm hover:-translate-y-1 transition-transform" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined text-[22px] dark-toggle-icon-moon">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:block text-[24px]">light_mode</span>
        </button>

        <a href="/admin" class="hidden sm:flex items-center gap-2 px-6 h-12 rounded-2xl font-bold text-sm bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-gray-600 dark:text-gray-300 shadow-sm hover:-translate-y-1 transition-transform">
          <span class="material-symbols-outlined text-[22px]">arrow_back</span> رجوع
        </a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-4 lg:px-8 pb-12">
      <div class="max-w-5xl mx-auto space-y-6 lg:space-y-8">

        <form method="post" action="<%= mode === 'new' ? '/admin/person/new' : ('/admin/person/' + person.id + '/edit') %>" class="bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark shadow-sm overflow-hidden relative p-6 md:p-8">
          
          <div class="absolute top-0 start-0 end-0 h-1 bg-gradient-to-l from-transparent via-accent to-transparent opacity-50"></div>

          <div class="mb-8 p-6 rounded-3xl border border-border-light dark:border-border-dark bg-black/5 dark:bg-white/5">
            <div class="mb-6">
              <h3 class="text-xl font-display font-bold text-primary dark:text-white flex items-center gap-2 mb-1">
                <span class="material-symbols-outlined text-accent">badge</span> المعلومات الأساسية
              </h3>
              <p class="text-gray-500 text-sm font-bold">الاسم، النسب، الجنس، الميلاد، والحالة</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الاسم</label>
                <input name="name" required value="<%= person?.name || '' %>" placeholder="مثال: أحمد محمد علي"
                       class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الأب</label>
                <select name="father_id" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0">
                  <option value="">— بدون —</option>
                  <% persons.forEach(x => { %>
                    <option value="<%= x.id %>" <%= person?.father_id == x.id ? 'selected' : '' %>><%= x.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الأم</label>
                <select name="mother_id" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0">
                  <option value="">— بدون —</option>
                  <% persons.forEach(x => { %>
                    <option value="<%= x.id %>" <%= person?.mother_id == x.id ? 'selected' : '' %>><%= x.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الجنس</label>
                <select name="gender" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0">
                  <option value="">— غير محدد —</option>
                  <option value="male" <%= (person?.gender === 'male' || person?.gender === 'ذكر') ? 'selected' : '' %>>ذكر</option>
                  <option value="female" <%= (person?.gender === 'female' || person?.gender === 'أنثى' || person?.gender === 'انثى') ? 'selected' : '' %>>أنثى</option>
                </select>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">العمل</label>
                <input name="job" value="<%= person?.job || '' %>" placeholder="مثال: مهندس / طبيب / ..."
                       class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">تاريخ الميلاد</label>
                <input name="birth_date" value="<%= person?.birth_date || '' %>" placeholder="مثال: 2004-08-20"
                       class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
              </div>

              <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">مكان الميلاد</label>
                <input name="birth_place" value="<%= person?.birth_place || '' %>" placeholder="مثال: جدة / مكة / القاهرة"
                       class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
              </div>

              <div class="md:col-span-2 rounded-2xl border border-border-light dark:border-border-dark bg-white/50 dark:bg-black/30 p-5 mt-2">
                <label class="flex items-center gap-3 cursor-pointer w-max">
                  <input id="is_deceased" name="is_deceased" value="1" type="checkbox" <%= Number(person?.is_deceased || 0) === 1 ? 'checked' : '' %>
                         class="w-5 h-5 rounded border-gray-300 text-primary dark:bg-black dark:border-gray-600 dark:checked:bg-accent focus:ring-0 transition-all"/>
                  <span class="text-sm font-bold text-gray-900 dark:text-white">الفرد متوفى</span>
                </label>

                <div id="deceasedFields" class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 <%= Number(person?.is_deceased || 0) === 1 ? '' : 'hidden' %>">
                  <div>
                    <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">تاريخ الوفاة</label>
                    <input name="death_date" id="death_date" value="<%= person?.death_date || '' %>" placeholder="مثال: 2020-01-01"
                           class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </div>
                  <div>
                    <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">مكان الوفاة</label>
                    <input name="death_place" id="death_place" value="<%= person?.death_place || '' %>" placeholder="مثال: مكة المكرمة"
                           class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="mb-8 p-6 rounded-3xl border border-border-light dark:border-border-dark bg-black/5 dark:bg-white/5">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
              <div>
                <h3 class="text-xl font-display font-bold text-primary dark:text-white flex items-center gap-2 mb-1">
                  <span class="material-symbols-outlined text-accent">favorite</span> الأزواج / الزوجات
                </h3>
                <p class="text-gray-500 text-sm font-bold">يمكن إضافة أكثر من شريك حياة.</p>
              </div>
              <button type="button" id="addSpouse" class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-bold bg-primary dark:bg-accent text-white dark:text-black hover:-translate-y-1 transition-transform shadow-sm">
                <span class="material-symbols-outlined text-[18px]">add</span> إضافة زوج/ة
              </button>
            </div>

            <div id="spousesWrap" class="grid gap-4">
              <% const list = (spouseNames && spouseNames.length) ? spouseNames : [""]; %>
              <% list.forEach((nm) => { %>
                <div class="spRow flex flex-col sm:flex-row gap-3 sm:items-center">
                  <input name="spouse_names" value="<%= nm %>" placeholder="مثال: نورة الخولي"
                         class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  <button type="button" class="spRemove flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-bold bg-white dark:bg-[#111] border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-300 hover:border-red-500 hover:text-red-600 dark:hover:border-red-500 dark:hover:text-red-400 transition-all sm:w-32 shrink-0">
                    <span class="material-symbols-outlined text-[18px]">delete</span> حذف
                  </button>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="mb-8 p-6 rounded-3xl border border-border-light dark:border-border-dark bg-black/5 dark:bg-white/5">
            <div class="mb-6">
              <h3 class="text-xl font-display font-bold text-primary dark:text-white flex items-center gap-2 mb-1">
                <span class="material-symbols-outlined text-accent">image</span> الصورة الموحدة
              </h3>
              <p class="text-gray-500 text-sm font-bold">هذه الصورة تستخدم في الشجرة والتفاصيل والسير الذاتية.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6 items-start">
              <div class="flex flex-col gap-4">
                <div class="rounded-2xl overflow-hidden border border-border-light dark:border-border-dark bg-white/50 dark:bg-black/30 shadow-sm p-2">
                  <img id="photoPreview" src="<%= person?.photo_url || '/images/default.png' %>" alt="معاينة" class="w-full h-64 object-cover rounded-xl"/>
                </div>

                <button type="button" id="clearPhoto" class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-bold bg-white dark:bg-[#111] border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-300 hover:border-primary dark:hover:border-accent transition-all">
                  <span class="material-symbols-outlined text-[18px]">backspace</span> مسح الصورة
                </button>

                <div id="uploadState" class="hidden rounded-xl border px-4 py-3 text-sm font-bold text-center"></div>
              </div>

              <div class="space-y-6">
                <div>
                  <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">رفع صورة جديدة</label>
                  <input type="file" id="photoFile" accept="image/*"
                         class="w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-sm file:font-bold file:transition-colors file:bg-primary/10 file:text-primary hover:file:bg-primary/20 dark:file:bg-accent/10 dark:file:text-accent dark:hover:file:bg-accent/20 cursor-pointer border border-border-light dark:border-border-dark bg-white/50 dark:bg-black/20 p-2 rounded-2xl"/>
                  <p class="mt-3 text-xs font-bold text-gray-500">ارفع الصورة مرة واحدة فقط، وسيتم استخدامها في كل صفحات الموقع.</p>
                </div>

                <div>
                  <label class="block text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">أو رابط الصورة (URL)</label>
                  <input name="photo_url" id="photo_url" value="<%= person?.photo_url || '' %>" placeholder="/uploads/xxx.jpg أو /images/xxx.jpg"
