                  <input type="file" name="image_file" accept="image/*" 
                         class="w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:transition-colors file:bg-primary/10 file:text-primary hover:file:bg-primary/20 dark:file:bg-accent/10 dark:file:text-accent dark:hover:file:bg-accent/20 cursor-pointer border border-border-light dark:border-border-dark bg-white/50 dark:bg-black/20 p-1.5 rounded-xl"/>
                </label>
