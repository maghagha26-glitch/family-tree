<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>قائمة السير الذاتية - شجرة العائلة</title>

  <script src="/theme.js"></script>
  <link rel="stylesheet" href="/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries,line-clamp"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",     /* اللون الأخضر الملكي الفاخر */
            primaryDark: "#003D1D", /* أخضر داكن للتحويم */
            accent: "#E5B869",      /* ذهب سائل */
            "background-light": "#F8F8F6",
            "background-dark": "#050505",
            "card-light": "#FFFFFF",
            "card-dark": "#0A0A0A",
            "bg-charcoal": "#050505",
            "bg-card": "#0A0A0A",
            "text-cream": "#FAFAFA",
            "muted-slate": "#71717A",
            gold: "#E5B869",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
          backgroundImage: {
            "islamic-pattern": "url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23E5B869' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")",
          }
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    }
  </style>

  <style>
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #E5B869; border-radius: 4px; }

    /* تأثيرات البطاقات السينمائية */
    .hon-card {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
      background: #000;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
    .dark .hon-card { box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

    .cinematic-img {
      width: 100%; height: 100%; object-fit: cover;
      opacity: 0.7; filter: grayscale(80%) contrast(1.1);
      transform: scale(1);
      transition: all 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    }
    .hon-card:hover .cinematic-img {
      opacity: 1;
      filter: grayscale(0%) contrast(1.1);
      transform: scale(1.08);
    }

    /* الإطار الذهبي الداخلي (البرواز) */
    .card-frame {
      position: absolute;
      inset: 12px;
      border: 1px solid rgba(229, 184, 105, 0);
      transition: border-color 0.8s ease, inset 0.8s ease;
      pointer-events: none;
      z-index: 20;
    }
    .hon-card:hover .card-frame {
      inset: 16px;
      border-color: rgba(229, 184, 105, 0.8);
    }

    .card-content {
      position: relative;
      z-index: 30;
      transform: translateY(20px);
      transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    }
    .hon-card:hover .card-content {
      transform: translateY(0);
    }

    .gold-accent-line {
      width: 0;
      height: 2px;
      background-color: #E5B869;
      transition: width 0.8s cubic-bezier(0.19, 1, 0.22, 1);
      margin-top: 8px;
    }
    .hon-card:hover .gold-accent-line {
      width: 40px;
    }

    .hon-card.auto-target {
      box-shadow: 0 0 0 2px #E5B869, 0 0 40px rgba(229, 184, 105, 0.3);
    }

    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer{
      transform: translateX(-110%);
      transition: transform .3s cubic-bezier(.2,.9,.2,1);
    }
    #mobileNavDrawer.isOpen{ transform: translateX(0); }
    #mobileNavBtn[data-open="true"] .ico-open { display: none; }
    #mobileNavBtn[data-open="true"] .ico-close { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-open { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-close { display: none; }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");

      const obs = new MutationObserver(() => {
        const t = document.documentElement.getAttribute("data-theme") || "dark";
        document.documentElement.classList.toggle("dark", t === "dark");
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    })();
  </script>
</head>

<body class="bg-background-light dark:bg-bg-charcoal text-gray-900 dark:text-text-cream font-sans min-h-screen flex flex-col overflow-x-hidden selection:bg-accent selection:text-background-dark transition-colors duration-300">

  <div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>
  <aside id="mobileNavDrawer" class="fixed top-0 left-0 h-full w-[320px] max-w-[85vw] bg-white dark:bg-bg-charcoal border-r border-gray-200 dark:border-white/10 shadow-2xl z-[90] flex flex-col">
    <div class="h-1.5 w-full bg-gradient-to-r from-gray-300 via-accent to-gray-300 dark:from-gray-800 dark:via-accent dark:to-gray-800"></div>
    <div class="flex items-center justify-between p-6 border-b border-gray-100 dark:border-white/5">
      <img class="h-10 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار" />
      <img class="h-10 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار" />
      <button id="mobileNavClose" class="text-gray-500 hover:text-accent transition-colors" type="button" aria-label="إغلاق القائمة">
        <span class="material-symbols-outlined text-[28px]">close</span>
      </button>
    </div>
    <nav class="p-6 flex flex-col gap-4 font-bold text-lg flex-grow text-gray-700 dark:text-gray-300" aria-label="قائمة الجوال">
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/">الشجرة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/about">نبذة</a>
      <a class="px-4 py-3 rounded-lg text-accent bg-accent/5 border-r-2 border-accent" href="/honor">قائمة السير الذاتية</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/news">أخبار العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/tree-pdf">مشجرة العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/support">الدعم</a>
    </nav>
    <div class="p-6 border-t border-gray-100 dark:border-white/5">
      <a href="/admin/login" class="flex items-center justify-center gap-2 py-3 bg-primary text-white dark:bg-white dark:text-primary rounded-lg hover:opacity-90 transition-colors font-bold" title="تسجيل الدخول">
        <span class="material-symbols-outlined">login</span>
      </a>
    </div>
  </aside>

  <header class="sticky top-0 z-50 w-full bg-white/95 dark:bg-[#050505]/95 backdrop-blur-md border-b border-gray-200 dark:border-white/10">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center h-20 md:h-24">
      
      <div class="flex items-center gap-4">
        <a href="/" class="block shrink-0">
          <img class="h-14 md:h-20 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار العائلة" />
          <img class="h-14 md:h-20 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار العائلة" />
        </a>
        
        <div class="h-10 w-px bg-gray-300 dark:bg-white/20"></div>
        
        <div class="flex items-center justify-center">
           <h1 class="text-2xl md:text-3xl font-display text-primary dark:text-accent font-bold leading-none tracking-wide pt-1">قائمة السير الذاتية</h1>
        </div>
      </div>

      <nav class="hidden lg:flex gap-6 xl:gap-8 items-center font-sans font-bold text-sm tracking-wide uppercase text-gray-600 dark:text-gray-400">
        <a class="hover:text-accent transition-colors" href="/">الشجرة</a>
        <a class="hover:text-accent transition-colors" href="/about">نبذة</a>
        <a class="text-primary dark:text-white border-b-2 border-accent pb-1" href="/honor">قائمة السير الذاتية</a>
        <a class="hover:text-accent transition-colors" href="/news">أخبار العائلة</a>
        <a class="hover:text-accent transition-colors" href="/tree-pdf">مشجرة العائلة</a>
        <a class="hover:text-accent transition-colors" href="/support">الدعم</a>
      </nav>

      <div class="flex items-center gap-3 shrink-0">
        <button id="uiThemeBtn" class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent hover:bg-gray-50 dark:hover:bg-white/5 transition-all" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined dark:hidden">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:inline">light_mode</span>
        </button>

        <a href="/admin/login" class="hidden sm:flex p-2.5 rounded-full bg-primary text-white dark:bg-white dark:text-black hover:opacity-90 transition-all shadow-md flex items-center justify-center" title="تسجيل الدخول">
          <span class="material-symbols-outlined text-[22px]">login</span>
        </a>

        <button id="mobileNavBtn" data-open="false" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-primary dark:text-accent hover:bg-gray-200 dark:hover:bg-white/10 transition-colors" type="button" aria-label="فتح القائمة">
          <span class="material-symbols-outlined text-[24px] ico-open">menu</span>
          <span class="material-symbols-outlined text-[24px] ico-close hidden">close</span>
        </button>
      </div>

    </div>
  </header>

  <main class="flex-grow relative">

    <section class="pt-20 pb-16 px-6 max-w-[90rem] mx-auto text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-islamic-pattern opacity-100 dark:opacity-30 pointer-events-none"></div>

      <img src="/assets/logo-dark.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] opacity-[0.03] pointer-events-none hidden dark:block" alt="">
      <img src="/assets/logo-light.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] opacity-[0.03] pointer-events-none block dark:hidden" alt="">

      <div class="w-px h-12 bg-accent mx-auto mb-6 relative z-10"></div>
      
      <h1 class="text-5xl md:text-7xl font-display leading-tight mb-4 relative z-10 font-bold drop-shadow-sm dark:drop-shadow-none">
        <span class="text-primary dark:text-white transition-colors duration-300">قائمة السير</span> <span class="text-accent">الذاتية</span>
      </h1>
      
      <p class="text-base md:text-lg font-sans text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed relative z-10">
        توثيقٌ بصري ومكتوب لسير قامات العائلة، نعرض فيه تاريخاً كُتب بماء الذهب ليبقى إرثاً تتوارثه الأجيال.
      </p>

      <div class="mt-12 max-w-md mx-auto relative group/search z-10">
        <input id="honorSearch" class="block w-full bg-transparent border-0 border-b-2 border-gray-300 dark:border-gray-700 focus:ring-0 focus:border-accent text-center text-lg py-3 placeholder-gray-400 dark:placeholder-gray-500 font-sans font-bold transition-colors" placeholder="ابحث بالاسم، الإنجاز، أو النبذة..." type="text" autocomplete="off" />
        <button id="clearSearch" type="button" class="absolute inset-y-0 left-0 flex items-center text-gray-400 hover:text-red-500 transition-colors" style="display:none" title="مسح">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
        <div class="mt-3 text-xs font-sans font-bold tracking-widest text-muted-slate uppercase">
          <span id="resultCount">النتائج: 0 / 0</span>
        </div>
      </div>
    </section>

    <section class="py-10 px-6 md:px-8 max-w-[100rem] mx-auto relative z-10">
      <% if (!items || items.length === 0) { %>
        <div class="text-center py-20 border border-dashed border-gray-300 dark:border-gray-700 max-w-2xl mx-auto p-12 rounded-2xl bg-white/50 dark:bg-black/50">
          <span class="material-symbols-outlined text-4xl text-accent mb-4">auto_awesome</span>
          <h2 class="text-2xl font-sans font-bold text-primary dark:text-white mb-2">القائمة فارغة حالياً</h2>
          <p class="font-sans text-gray-500">أضف عناصر من لوحة الإدارة → إدارة السير الذاتية.</p>
        </div>
      <% } else { %>
        
        <div id="honorGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
          <% for (let i=0; i<items.length; i++){ const x = items[i]; %>
            
            <article
              class="hon-card group cursor-pointer js-open-details aspect-[3/4] sm:aspect-[2/3] flex flex-col"
              id="honor-item-<%= x.id %>"
              data-id="<%= x.id %>"
              data-person-id="<%= x.person_id || x.id %>"
              data-search="<%= [x.name||'', x.field||'', x.achievement||'', x.bio||'', x.birth_date||'', x.death_date||'', x.birth_place||''].join(' ') %>"
              data-name="<%= x.name || '' %>"
              data-field="<%= x.field || '' %>"
              data-achievement="<%= x.achievement || '' %>"
              data-bio="<%= x.bio || '' %>"
              data-birth-date="<%= x.birth_date || '' %>"
              data-death-date="<%= x.death_date || '' %>"
              data-birth-place="<%= x.birth_place || '' %>"
              data-photo="<%= x.photo_url || '' %>"
            >
              <div class="absolute inset-0 bg-gray-200 dark:bg-[#0a0a0a]">
                <% if (x.photo_url) { %>
                  <img alt="<%= x.name %>" class="cinematic-img" src="<%= x.photo_url %>" loading="lazy" />
                <% } else { %>
                  <div class="w-full h-full flex flex-col items-center justify-center bg-gray-200 dark:bg-gradient-to-b dark:from-[#111] dark:to-[#000]">
                     <span class="material-symbols-outlined text-[80px] text-gray-400 dark:text-white/5">person</span>
                  </div>
                <% } %>
              </div>

              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent opacity-80 dark:opacity-90 group-hover:opacity-100 transition-opacity duration-700"></div>

              <div class="card-frame"></div>

              <div class="mt-auto p-6 md:p-8 card-content flex flex-col justify-end h-full">
                <% if (x.field) { %>
                  <p class="text-[11px] font-sans font-bold uppercase tracking-[0.2em] text-accent mb-2"><%= x.field %></p>
                <% } %>
                
                <h3 class="text-3xl lg:text-4xl font-display text-white mb-1 leading-tight drop-shadow-md">
                  <%= x.name %>
                </h3>
                <div class="gold-accent-line"></div>

                <div class="overflow-hidden h-0 group-hover:h-[60px] transition-all duration-700 ease-in-out mt-0 group-hover:mt-3 opacity-0 group-hover:opacity-100">
                  <% if (x.achievement || x.bio) { %>
                    <p class="text-sm font-sans text-gray-300 line-clamp-2 leading-relaxed">
                      <%= ((x.achievement || x.bio) || "").replace(/\n/g, " ") %>
                    </p>
                  <% } %>
                </div>

                <div class="mt-4 pt-4 border-t border-white/20 w-full flex justify-between items-center relative z-40 opacity-0 group-hover:opacity-100 transition-opacity duration-700 delay-100">
                  <a href="/?highlight=<%= x.person_id || x.id %>" class="text-xs text-gray-300 font-sans font-bold tracking-wide hover:text-accent transition-colors flex items-center gap-1" onclick="event.stopPropagation()">
                    <span class="material-symbols-outlined text-[16px]">account_tree</span> موقعي بالشجرة
                  </a>

                  <button type="button" class="text-accent hover:text-white font-sans font-bold text-sm flex items-center gap-1">
                    التفاصيل <span class="material-symbols-outlined text-[16px] rtl:rotate-180">arrow_forward</span>
                  </button>
                </div>
              </div>

            </article>

          <% } %>
        </div>

        <div id="noResults" class="hidden py-16 text-center max-w-lg mx-auto">
          <div class="w-px h-12 bg-gray-300 dark:bg-gray-700 mx-auto mb-6"></div>
          <h2 class="text-xl font-sans font-bold text-gray-500">لم يتم العثور على نتائج مطابقة لبحثك</h2>
        </div>

      <% } %>
    </section>

    <div id="detailsModal" class="fixed inset-0 z-[100] hidden overflow-y-auto overscroll-contain">
      <div class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-12">
        <div id="detailsBackdrop" class="fixed inset-0 bg-black/80 backdrop-blur-md transition-opacity"></div>

        <div class="relative w-full max-w-6xl max-h-[90vh] bg-white dark:bg-[#050505] border border-gray-200 dark:border-white/10 rounded-2xl shadow-2xl flex flex-col lg:flex-row overflow-hidden z-10 transform scale-95 transition-all duration-300">
          
          <button id="detailsCloseBtn" type="button" class="absolute top-4 left-4 z-50 w-10 h-10 rounded-full bg-black/10 dark:bg-white/10 hover:bg-black/20 dark:hover:bg-white/20 flex items-center justify-center text-gray-700 dark:text-gray-300 transition-colors border border-gray-300 dark:border-white/10" aria-label="إغلاق">
            <span class="material-symbols-outlined text-[20px]">close</span>
          </button>

          <div class="w-full lg:w-5/12 h-[35vh] lg:h-auto relative bg-gray-100 dark:bg-black shrink-0 overflow-hidden">
             <img id="detailsPhoto" src="" alt="" class="w-full h-full object-cover opacity-100 hidden"/>
             <div id="detailsPhotoFallback" class="w-full h-full flex flex-col items-center justify-center text-gray-400 dark:text-white/5">
               <span class="material-symbols-outlined text-[80px]">person</span>
             </div>
             <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-white dark:from-[#050505] to-transparent opacity-100 pointer-events-none"></div>
          </div>

          <div class="w-full lg:w-7/12 flex flex-col overflow-hidden bg-white dark:bg-[#050505]">
            <div class="p-6 md:p-10 lg:p-12 overflow-y-auto custom-scrollbar flex-grow text-right">
              
              <p id="detailsField" class="text-xs font-sans font-bold uppercase tracking-[0.2em] text-accent mb-3"></p>
              <h4 id="detailsName" class="text-4xl md:text-5xl lg:text-6xl font-display text-primary dark:text-white leading-tight mb-6"></h4>
              
              <div id="detailsMeta" class="mb-8 flex flex-wrap gap-4 border-b border-gray-200 dark:border-white/10 pb-6 empty:hidden"></div>

              <div class="space-y-8 font-sans">
                <div>
                  <h5 class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-3">الإنجازات والمآثر</h5>
                  <p id="detailsAchievement" class="text-base text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-line"></p>
                </div>

                <div>
                  <h5 class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-3">السيرة والنبذة</h5>
                  <p id="detailsBio" class="text-base text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-line"></p>
                </div>
              </div>
            </div>
            
            <div class="p-6 border-t border-gray-100 dark:border-white/5 flex justify-between items-center shrink-0 bg-gray-50 dark:bg-black/50">
              <a id="treePosBtn" href="#" class="flex items-center gap-2 text-primary dark:text-accent font-sans font-bold hover:underline transition-colors">
                <span class="material-symbols-outlined">account_tree</span> موقعي في الشجرة
              </a>
              <button id="detailsCloseBtn2" type="button" class="px-6 py-2.5 rounded-lg bg-gray-200 dark:bg-white/10 text-gray-800 dark:text-white font-sans font-bold hover:bg-gray-300 dark:hover:bg-white/20 transition-colors">
                إغلاق النافذة
              </button>
            </div>

          </div>
        </div>
      </div>
    </div>

  </main>

  <footer class="bg-background-light dark:bg-bg-charcoal border-t border-gray-200 dark:border-white/10 mt-auto py-8 relative z-10">
    <div class="max-w-[90rem] mx-auto px-6 text-center flex flex-col items-center gap-3">
      <p class="text-[11px] font-sans font-bold text-gray-500 uppercase tracking-[0.1em]">
        © ٢٠٢٦ وقف عائلة خاشقجي. جميع الحقوق محفوظة.
      </p>
    </div>
  </footer>

  <script>
    (function () {
      const btn = document.getElementById("uiThemeBtn");
      function applyTheme(next) {
        document.documentElement.setAttribute("data-theme", next);
        document.documentElement.classList.toggle("dark", next === "dark");
        localStorage.setItem("theme", next);
      }
      btn?.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme") || "dark";
        applyTheme(current === "dark" ? "light" : "dark");
      });
      applyTheme(localStorage.getItem("theme") || "dark");
    })();

    (function mobileNavInit(){
      const btn = document.getElementById("mobileNavBtn");
      const navDrawer = document.getElementById("mobileNavDrawer");
      const overlay = document.getElementById("mobileNavOverlay");
      const closeBtn = document.getElementById("mobileNavClose");

      function setOpenState(isOpen){
        btn?.setAttribute("data-open", isOpen ? "true" : "false");
        btn?.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }

      function openNav(){
        overlay?.classList.remove("hidden");
        navDrawer?.classList.add("isOpen");
        setOpenState(true);
      }
      function closeNav(){
        navDrawer?.classList.remove("isOpen");
        overlay?.classList.add("hidden");
        setOpenState(false);
      }

      btn?.addEventListener("click", () => {
        const open = btn.getAttribute("data-open") === "true";
        open ? closeNav() : openNav();
      });

      closeBtn?.addEventListener("click", closeNav);
      overlay?.addEventListener("click", closeNav);
      navDrawer?.querySelectorAll("a").forEach(a => a.addEventListener("click", closeNav));
      window.addEventListener("keydown", (e) => { if (e.key === "Escape") closeNav(); });

      setOpenState(false);
    })();
  </script>

  <script>
    (function(){
      const input = document.getElementById("honorSearch");
      const clearBtn = document.getElementById("clearSearch");
      const grid = document.getElementById("honorGrid");
      const cards = grid ? Array.from(grid.querySelectorAll(".hon-card")) : [];
      const counter = document.getElementById("resultCount");
      const noResults = document.getElementById("noResults");
      const total = cards.length;

      function norm(str){
        return (str || "")
          .toString()
          .toLowerCase()
          .replace(/[\u064B-\u065F\u0670]/g, "")
          .replace(/[إأآا]/g, "ا")
          .replace(/ى/g, "ي")
          .replace(/ؤ/g, "و")
          .replace(/ئ/g, "ي")
          .replace(/ة/g, "ه")
          .replace(/\s+/g, " ")
          .trim();
      }

      window.__honorNorm = norm;

      function update(){
        const q = norm(input?.value);
        let shown = 0;

        cards.forEach(card => {
          const hay = norm(card.getAttribute("data-search"));
          const ok = !q || hay.includes(q);
          card.classList.toggle("hidden", !ok);
          if (ok) shown++;
        });

        if (counter) counter.textContent = `النتائج: ${shown} / ${total}`;
        if (noResults) noResults.classList.toggle("hidden", shown !== 0);
        if (clearBtn) clearBtn.style.display = q ? "flex" : "none";
      }

      input?.addEventListener("input", update);
      clearBtn?.addEventListener("click", () => {
        if (!input) return;
        input.value = "";
        input.focus();
        update();
      });

      update();
    })();
  </script>

  <script>
    (function(){
      const modal = document.getElementById("detailsModal");
      const backdrop = document.getElementById("detailsBackdrop");
      const close1 = document.getElementById("detailsCloseBtn");
      const close2 = document.getElementById("detailsCloseBtn2");
      const modalContent = modal.querySelector('.max-w-6xl');

      const elName = document.getElementById("detailsName");
      const elField = document.getElementById("detailsField");
      const elAch = document.getElementById("detailsAchievement");
      const elBio = document.getElementById("detailsBio");
      const elMeta = document.getElementById("detailsMeta");
      const elPhoto = document.getElementById("detailsPhoto");
      const elPhotoFallback = document.getElementById("detailsPhotoFallback");
      const treePosBtn = document.getElementById("treePosBtn");

      function openDetails(data){
        const name = data.name || "";
        const field = data.field || "";
        const achievement = data.achievement || "";
        const bio = data.bio || "";
        const photo = data.photo || "";
        const birthDate = data.birthDate || "";
        const deathDate = data.deathDate || "";
        const birthPlace = data.birthPlace || "";
        const personId = data.personId || "";

        elName.textContent = name;
        elField.textContent = field || "";
        elAch.textContent = achievement || "-";
        elBio.textContent = bio || "-";

        if (elMeta) {
          const meta = [];
          if (birthDate) meta.push(`<div class="text-sm font-sans px-3 py-1.5 bg-gray-100 dark:bg-white/5 rounded-lg border border-gray-200 dark:border-white/5"><span class="text-gray-500 ml-1">الميلاد:</span> <span class="font-bold text-gray-800 dark:text-gray-200">${birthDate}</span></div>`);
          if (deathDate) meta.push(`<div class="text-sm font-sans px-3 py-1.5 bg-gray-100 dark:bg-white/5 rounded-lg border border-gray-200 dark:border-white/5"><span class="text-gray-500 ml-1">الوفاة:</span> <span class="font-bold text-gray-800 dark:text-gray-200">${deathDate}</span></div>`);
          if (birthPlace) meta.push(`<div class="text-sm font-sans px-3 py-1.5 bg-gray-100 dark:bg-white/5 rounded-lg border border-gray-200 dark:border-white/5"><span class="text-gray-500 ml-1">المكان:</span> <span class="font-bold text-gray-800 dark:text-gray-200">${birthPlace}</span></div>`);
          elMeta.innerHTML = meta.join('');
        }

        if (photo) {
          elPhoto.src = photo;
          elPhoto.alt = name;
          elPhoto.classList.remove("hidden");
          elPhotoFallback.classList.add("hidden");
        } else {
          elPhoto.src = "";
          elPhoto.alt = "";
          elPhoto.classList.add("hidden");
          elPhotoFallback.classList.remove("hidden");
        }

        if(treePosBtn && personId) {
            treePosBtn.href = `/?highlight=${personId}`;
        }

        modal.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");

        setTimeout(() => {
            modalContent.classList.remove("scale-95");
            modalContent.classList.add("scale-100");
        }, 10);
      }

      function openFromCard(card){
        openDetails({
          name: card.getAttribute("data-name") || "",
          field: card.getAttribute("data-field") || "",
          achievement: card.getAttribute("data-achievement") || "",
          bio: card.getAttribute("data-bio") || "",
          birthDate: card.getAttribute("data-birth-date") || "",
          deathDate: card.getAttribute("data-death-date") || "",
          birthPlace: card.getAttribute("data-birth-place") || "",
          photo: card.getAttribute("data-photo") || "",
          personId: card.getAttribute("data-person-id") || card.getAttribute("data-id") || ""
        });
      }

      function close(){
        modalContent.classList.remove("scale-100");
        modalContent.classList.add("scale-95");
        setTimeout(() => {
            modal.classList.add("hidden");
            document.body.classList.remove("overflow-hidden");
        }, 300);
      }

      window.__openHonorDetailsFromCard = openFromCard;
      window.__openHonorDetails = openDetails;

      document.addEventListener("click", (e) => {
        const btn = e.target.closest(".js-open-details");
        if (!btn) return;
        if(e.target.closest("a[href^='/?highlight']")) return; 

        const card = btn.closest(".hon-card");
        if (!card) return;
        openFromCard(card);
      });

      backdrop?.addEventListener("click", close);
      close1?.addEventListener("click", close);
      close2?.addEventListener("click", close);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
      });
    })();
  </script>

  <script>
    (function autoOpenFromPersonId(){
      const params = new URLSearchParams(window.location.search);
      const personId = params.get("personId");
      if (!personId) return;

      function norm(str){
        return window.__honorNorm
          ? window.__honorNorm(str)
          : String(str || "").toLowerCase().trim();
      }

      function highlightAndOpenCard(card){
        if (!card) return false;

        card.classList.remove("hidden");
        card.classList.add("auto-target");

        setTimeout(() => {
          card.scrollIntoView({ behavior: "smooth", block: "center" });
        }, 250);

        setTimeout(() => {
          if (window.__openHonorDetailsFromCard) {
            window.__openHonorDetailsFromCard(card);
          }
        }, 650);

        return true;
      }

      async function run(){
        const cards = Array.from(document.querySelectorAll(".hon-card"));

        let exactCard = document.querySelector(`.hon-card[data-id="${CSS.escape(personId)}"]`);
        if (highlightAndOpenCard(exactCard)) return;

        try {
          const res = await fetch(`/api/person/${encodeURIComponent(personId)}`);
          if (!res.ok) return;

          const person = await res.json();
          const personName = norm(person.name || "");

          const sameNameCard = cards.find(card => norm(card.getAttribute("data-name")) === personName);
          if (highlightAndOpenCard(sameNameCard)) return;

          if (window.__openHonorDetails) {
            window.__openHonorDetails({
              name: person.name || "",
              field: person.job || "",
              achievement: person.notes || "",
              bio: person.short_bio || person.notes || "",
              birthDate: person.birth_date || "",
              deathDate: person.death_date || "",
              birthPlace: person.birth_place || "",
              photo: person.photo_url || "",
              personId: personId
            });
          }
        } catch (err) {
          console.error("autoOpenFromPersonId error:", err);
        }
      }

      run();
    })();
  </script>

