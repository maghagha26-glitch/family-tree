<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>أخبار العائلة - شجرة العائلة</title>

  <script src="/theme.js"></script>
  <link rel="stylesheet" href="/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries,line-clamp"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",
            primaryDark: "#003D1D",
            accent: "#E5B869",
            "background-light": "#F8F8F6",
            "background-dark": "#050505",
            "card-light": "#FFFFFF",
            "card-dark": "#0A0A0A",
            "bg-charcoal": "#050505",
            "bg-card": "#0A0A0A",
            "text-cream": "#FAFAFA",
            "muted-slate": "#71717A",
            gold: "#E5B869",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
          backgroundImage: {
            "islamic-pattern": "url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23E5B869' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")",
          }
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    }
  </style>

  <style>
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #E5B869; border-radius: 4px; }

    .news-card {
      position: relative;
      overflow: hidden;
      border-radius: 22px;
      background: rgba(255,255,255,.86);
      border: 1px solid rgba(229,184,105,.24);
      box-shadow: 0 18px 45px rgba(0,0,0,.08);
      transition: transform .45s ease, box-shadow .45s ease, border-color .45s ease;
      isolation: isolate;
    }
    .dark .news-card {
      background: linear-gradient(180deg, rgba(18,18,18,.95), rgba(7,7,7,.98));
      border-color: rgba(255,255,255,.1);
      box-shadow: 0 18px 45px rgba(0,0,0,.38);
    }
    .news-card:hover {
      transform: translateY(-8px);
      border-color: rgba(229,184,105,.55);
      box-shadow: 0 26px 70px rgba(0,0,0,.14);
    }
    .dark .news-card:hover { box-shadow: 0 26px 70px rgba(0,0,0,.62); }

    .news-image-wrap {
      position: relative;
      display: block;
      height: 245px;
      overflow: hidden;
      background: #eee;
      border-bottom: 1px solid rgba(229,184,105,.18);
    }
    .dark .news-image-wrap { background: #050505; border-bottom-color: rgba(255,255,255,.08); }
    .news-image-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(0,0,0,.48), transparent 55%),
        radial-gradient(circle at top right, rgba(229,184,105,.20), transparent 45%);
      z-index: 3;
      pointer-events: none;
    }
    .news-image-blur {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: blur(22px);
      transform: scale(1.18);
      opacity: .28;
      z-index: 1;
    }
    .news-image-main {
      position: relative;
      z-index: 2;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1);
      transition: transform .75s cubic-bezier(0.19, 1, 0.22, 1), filter .75s ease;
    }
    .news-card:hover .news-image-main {
      transform: scale(1.06);
      filter: saturate(1.05) contrast(1.03);
    }

    .news-date-badge {
      position: absolute;
      right: 18px;
      bottom: 18px;
      z-index: 6;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      max-width: calc(100% - 36px);
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(229,184,105,.55);
      background: rgba(0,0,0,.55);
      color: #fff;
      backdrop-filter: blur(10px);
      font-size: 11px;
      font-weight: 800;
    }

    .news-content {
      position: relative;
      padding: 22px;
      min-height: 245px;
      display: flex;
      flex-direction: column;
      background:
        linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,255,255,.96)),
        radial-gradient(circle at top left, rgba(229,184,105,.14), transparent 38%);
    }
    .dark .news-content {
      background:
        linear-gradient(180deg, rgba(13,13,13,.94), rgba(5,5,5,.99)),
        radial-gradient(circle at top left, rgba(229,184,105,.10), transparent 40%);
    }

    .news-category-pill {
      width: fit-content;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(0,90,43,.08);
      color: #005A2B;
      border: 1px solid rgba(0,90,43,.12);
      font-size: 11px;
      font-weight: 900;
      margin-bottom: 12px;
    }
    .dark .news-category-pill {
      color: #E5B869;
      background: rgba(229,184,105,.08);
      border-color: rgba(229,184,105,.16);
    }

    .news-title-link {
      color: #111827;
      transition: color .25s ease;
    }
    .dark .news-title-link { color: #fff; }
    .news-title-link:hover { color: #E5B869; }

    .news-separator {
      width: 54px;
      height: 2px;
      margin: 14px 0 14px auto;
      background: linear-gradient(to left, #E5B869, rgba(229,184,105,0));
      transition: width .45s ease;
    }
    .news-card:hover .news-separator { width: 92px; }

    .news-footer {
      margin-top: auto;
      padding-top: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid rgba(0,0,0,.08);
    }
    .dark .news-footer { border-top-color: rgba(255,255,255,.09); }

    .read-more-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #005A2B;
      font-weight: 900;
      font-size: 13px;
      transition: color .25s ease, transform .25s ease;
    }
    .dark .read-more-btn { color: #E5B869; }
    .read-more-btn:hover { color: #E5B869; transform: translateX(-3px); }

    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer{
      transform: translateX(-110%);
      transition: transform .3s cubic-bezier(.2,.9,.2,1);
    }
    #mobileNavDrawer.isOpen{ transform: translateX(0); }
    #mobileNavBtn[data-open="true"] .ico-open { display: none; }
    #mobileNavBtn[data-open="true"] .ico-close { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-open { display: inline; }
    #mobileNavBtn[data-open="false"] .ico-close { display: none; }

    .royal-panel {
      background:
        linear-gradient(135deg, rgba(255,255,255,.92), rgba(255,255,255,.72)),
        radial-gradient(circle at top right, rgba(229,184,105,.14), transparent 45%);
    }
    .dark .royal-panel {
      background:
        linear-gradient(135deg, rgba(10,10,10,.92), rgba(5,5,5,.76)),
        radial-gradient(circle at top right, rgba(229,184,105,.16), transparent 45%);
    }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");

      const obs = new MutationObserver(() => {
        const t = document.documentElement.getAttribute("data-theme") || "dark";
        document.documentElement.classList.toggle("dark", t === "dark");
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    })();
  </script>
</head>

<body class="bg-background-light dark:bg-bg-charcoal text-gray-900 dark:text-text-cream font-sans min-h-screen flex flex-col overflow-x-hidden selection:bg-accent selection:text-background-dark transition-colors duration-300">

  <div id="mobileNavOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[80] hidden" aria-hidden="true"></div>
  <aside id="mobileNavDrawer" class="fixed top-0 left-0 h-full w-[320px] max-w-[85vw] bg-white dark:bg-bg-charcoal border-r border-gray-200 dark:border-white/10 shadow-2xl z-[90] flex flex-col">
    <div class="h-1.5 w-full bg-gradient-to-r from-gray-300 via-accent to-gray-300 dark:from-gray-800 dark:via-accent dark:to-gray-800"></div>
    <div class="flex items-center justify-between p-6 border-b border-gray-100 dark:border-white/5">
      <img class="h-10 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار" />
      <img class="h-10 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار" />
      <button id="mobileNavClose" class="text-gray-500 hover:text-accent transition-colors" type="button" aria-label="إغلاق القائمة">
        <span class="material-symbols-outlined text-[28px]">close</span>
      </button>
    </div>
    <nav class="p-6 flex flex-col gap-4 font-bold text-lg flex-grow text-gray-700 dark:text-gray-300" aria-label="قائمة الجوال">
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/">الشجرة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/about">نبذة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/honor">قائمة السير الذاتية</a>
      <a class="px-4 py-3 rounded-lg text-accent bg-accent/5 border-r-2 border-accent" href="/news">أخبار العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/tree-pdf">مشجرة العائلة</a>
      <a class="px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-white/5 transition-colors" href="/support">الدعم</a>
    </nav>
    <div class="p-6 border-t border-gray-100 dark:border-white/5">
      <a href="/admin/login" class="flex items-center justify-center gap-2 py-3 bg-primary text-white dark:bg-white dark:text-primary rounded-lg hover:opacity-90 transition-colors font-bold" title="تسجيل الدخول">
        <span class="material-symbols-outlined">login</span>
      </a>
    </div>
  </aside>

  <header class="sticky top-0 z-50 w-full bg-white/95 dark:bg-[#050505]/95 backdrop-blur-md border-b border-gray-200 dark:border-white/10">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center h-20 md:h-24">
      <div class="flex items-center gap-4">
        <a href="/" class="block shrink-0">
          <img class="h-14 md:h-20 w-auto hidden dark:block" src="/assets/logo-dark.svg" alt="شعار العائلة" />
          <img class="h-14 md:h-20 w-auto block dark:hidden" src="/assets/logo-light.svg" alt="شعار العائلة" />
        </a>
        <div class="h-10 w-px bg-gray-300 dark:bg-white/20"></div>
        <div class="flex items-center justify-center">
           <h1 class="text-2xl md:text-3xl font-display text-primary dark:text-accent font-bold leading-none tracking-wide pt-1">أخبار العائلة</h1>
        </div>
      </div>

      <nav class="hidden lg:flex gap-6 xl:gap-8 items-center font-sans font-bold text-sm tracking-wide uppercase text-gray-600 dark:text-gray-400">
        <a class="hover:text-accent transition-colors" href="/">الشجرة</a>
        <a class="hover:text-accent transition-colors" href="/about">نبذة</a>
        <a class="hover:text-accent transition-colors" href="/honor">قائمة السير الذاتية</a>
        <a class="text-primary dark:text-white border-b-2 border-accent pb-1" href="/news">أخبار العائلة</a>
        <a class="hover:text-accent transition-colors" href="/tree-pdf">مشجرة العائلة</a>
        <a class="hover:text-accent transition-colors" href="/support">الدعم</a>
      </nav>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent hover:bg-gray-50 dark:hover:bg-white/5 transition-all" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined dark:hidden">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:inline">light_mode</span>
        </button>

        <a href="/admin/login" class="hidden sm:flex p-2.5 rounded-full bg-primary text-white dark:bg-white dark:text-black hover:opacity-90 transition-all shadow-md flex items-center justify-center" title="تسجيل الدخول">
          <span class="material-symbols-outlined text-[22px]">login</span>
        </a>

        <button id="mobileNavBtn" data-open="false" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-primary dark:text-accent hover:bg-gray-200 dark:hover:bg-white/10 transition-colors" type="button" aria-label="فتح القائمة" aria-expanded="false">
          <span class="material-symbols-outlined text-[24px] ico-open">menu</span>
          <span class="material-symbols-outlined text-[24px] ico-close hidden">close</span>
        </button>
      </div>
    </div>
  </header>

  <main class="flex-grow relative">

    <section class="pt-20 pb-12 px-6 max-w-[90rem] mx-auto text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-islamic-pattern opacity-100 dark:opacity-30 pointer-events-none"></div>
      <img src="/assets/logo-dark.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[620px] opacity-[0.03] pointer-events-none hidden dark:block" alt="">
      <img src="/assets/logo-light.svg" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[620px] opacity-[0.03] pointer-events-none block dark:hidden" alt="">

      <div class="w-px h-12 bg-accent mx-auto mb-6 relative z-10"></div>
      
      <h1 class="text-5xl md:text-7xl font-display leading-tight mb-4 relative z-10 font-bold drop-shadow-sm dark:drop-shadow-none">
        <span class="text-primary dark:text-white transition-colors duration-300">أخبار</span> <span class="text-accent">العائلة</span>
      </h1>
      
      <p class="text-base md:text-lg font-sans text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed relative z-10">
        نافذة رسمية لمتابعة أخبار العائلة والمناسبات والإعلانات المهمة، بتصميم يحفظ الوقار ويعرض المحتوى بروح تراثية راقية.
      </p>
    </section>

    <section class="px-6 md:px-8 pb-10 relative z-10">
      <div class="max-w-[90rem] mx-auto">
        <div id="subscribeSuccess" class="hidden mb-4 rounded-2xl border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3 font-bold dark:bg-emerald-500/10 dark:border-emerald-500/20 dark:text-emerald-300">
          تم الاشتراك بنجاح في أخبار العائلة.
        </div>
        <div id="subscribeInvalid" class="hidden mb-4 rounded-2xl border border-amber-200 bg-amber-50 text-amber-800 px-4 py-3 font-bold dark:bg-amber-500/10 dark:border-amber-500/20 dark:text-amber-300">
          البريد الإلكتروني غير صحيح. برجاء المحاولة مرة أخرى.
        </div>
        <div id="subscribeError" class="hidden mb-4 rounded-2xl border border-red-200 bg-red-50 text-red-700 px-4 py-3 font-bold dark:bg-red-500/10 dark:border-red-500/20 dark:text-red-300">
          حدث خطأ أثناء الاشتراك. برجاء المحاولة لاحقًا.
        </div>

        <div class="royal-panel relative overflow-hidden rounded-[2rem] border border-gray-200 dark:border-white/10 shadow-sm">
          <div class="absolute inset-0 bg-islamic-pattern opacity-80 dark:opacity-25 pointer-events-none"></div>
          <div class="relative p-6 md:p-8 lg:p-10 grid grid-cols-1 lg:grid-cols-[1fr_1.55fr] gap-6 lg:items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent text-xs font-black mb-4">
                <span class="material-symbols-outlined text-[16px]">notifications_active</span>
                النشرة البريدية
              </div>
              <h2 class="text-3xl md:text-4xl font-display font-bold text-primary dark:text-white mb-3">
                اشترك ليصلك كل جديد
              </h2>
              <p class="text-sm md:text-base text-gray-600 dark:text-gray-400 leading-relaxed">
                أدخل بريدك الإلكتروني ليصلك إشعار عند نشر أخبار أو مناسبات جديدة للعائلة.
              </p>
            </div>

            <form method="post" action="/news/subscribe" class="grid grid-cols-1 sm:grid-cols-[1fr_1.35fr_auto] gap-3">
              <input name="subscriber_name" type="text" autocomplete="name" placeholder="الاسم - اختياري" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-white/80 dark:bg-black/35 text-sm font-bold focus:outline-none focus:ring-2 focus:ring-accent/30"/>
              <input name="email" type="email" required autocomplete="email" placeholder="البريد الإلكتروني" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-white/80 dark:bg-black/35 text-sm font-bold focus:outline-none focus:ring-2 focus:ring-accent/30"/>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-primary text-white dark:bg-white dark:text-primary font-black hover:opacity-90 transition-colors">
                <span class="material-symbols-outlined text-[18px]">send</span>
                اشتراك
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 md:px-8 pb-6 relative z-10">
      <div class="max-w-xl mx-auto relative group/search">
        <input id="searchInput" class="block w-full bg-transparent border-0 border-b-2 border-gray-300 dark:border-gray-700 focus:ring-0 focus:border-accent text-center text-lg py-3 placeholder-gray-400 dark:placeholder-gray-500 font-sans font-bold transition-colors" placeholder="ابحث في الأخبار..." type="text" autocomplete="off" />
        <span class="absolute inset-y-0 right-0 flex items-center text-accent pointer-events-none">
          <span class="material-symbols-outlined text-[22px]">search</span>
        </span>
      </div>
    </section>

    <section class="py-10 px-6 md:px-8 max-w-[100rem] mx-auto relative z-10">
      <% if (!posts || posts.length === 0) { %>
        <div class="text-center py-20 border border-dashed border-gray-300 dark:border-gray-700 max-w-2xl mx-auto p-12 rounded-2xl bg-white/50 dark:bg-black/50">
          <span class="material-symbols-outlined text-4xl text-accent mb-4">newspaper</span>
          <h2 class="text-2xl font-sans font-bold text-primary dark:text-white mb-2">لا توجد أخبار حالياً</h2>
          <p class="font-sans text-gray-500">عند إضافة أخبار جديدة ستظهر هنا مباشرة.</p>
        </div>
      <% } else { %>
        <div id="newsGrid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-7 md:gap-8">
          <% posts.forEach(p => {
            const img = p.image_url || p.person_photo_url || "/images/default.png";
          %>
            <article class="news-card group">
              <a href="/news/<%= p.id %>" class="news-image-wrap" aria-label="<%= p.title || 'خبر' %>">
                <img src="<%= img %>" alt="" class="news-image-blur" loading="lazy" decoding="async" onerror="this.style.display='none'" />
                <img src="<%= img %>" alt="<%= p.title || 'خبر' %>" class="news-image-main" loading="lazy" decoding="async" onerror="this.src='/images/default.png'" />
                <span class="news-date-badge">
                  <span class="material-symbols-outlined text-[15px]">calendar_month</span>
                  <span class="truncate"><%= p.event_date || p.published_at || 'خبر جديد' %></span>
                </span>
              </a>

              <div class="news-content">
                <span class="news-category-pill">
                  <span class="material-symbols-outlined text-[15px]">article</span>
                  خبر عائلي
                </span>

                <h2 class="text-2xl md:text-[1.7rem] font-display font-bold leading-tight line-clamp-2">
                  <a href="/news/<%= p.id %>" class="news-title-link"><%= p.title %></a>
                </h2>

                <div class="news-separator"></div>

                <p class="text-sm md:text-[15px] font-sans text-gray-600 dark:text-gray-400 line-clamp-3 leading-relaxed mb-4">
                  <%= p.summary || p.content || '' %>
                </p>

                <% if (p.person_id) { %>
                  <div class="mb-4 text-xs text-primary dark:text-accent font-bold flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">person</span>
                    مرتبط بـ: <%= p.person_name || ('#' + p.person_id) %>
                  </div>
                <% } %>

                <div class="news-footer">
                  <span class="text-[11px] text-gray-500 dark:text-gray-500 font-bold truncate">
                    <%= p.event_date || p.published_at || '' %>
                  </span>
                  <a href="/news/<%= p.id %>" class="read-more-btn">
                    اقرأ المزيد
                    <span class="material-symbols-outlined text-[16px] rtl:rotate-180">arrow_forward</span>
                  </a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

        <div id="noResults" class="hidden py-16 text-center max-w-lg mx-auto">
          <div class="w-px h-12 bg-gray-300 dark:bg-gray-700 mx-auto mb-6"></div>
          <h2 class="text-xl font-sans font-bold text-gray-500">لا توجد نتائج</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">جرّب كلمة بحث أخرى.</p>
        </div>
      <% } %>
    </section>

  </main>

  <footer class="bg-background-light dark:bg-bg-charcoal border-t border-gray-200 dark:border-white/10 mt-auto py-8 relative z-10">
    <div class="max-w-[90rem] mx-auto px-6 text-center flex flex-col items-center gap-3">
      <p class="text-[11px] font-sans font-bold text-gray-500 uppercase tracking-[0.1em]">
        © ٢٠٢٦ وقف عائلة خاشقجي. جميع الحقوق محفوظة.
      </p>
    </div>
  </footer>

  <script>
    (function () {
      const btn = document.getElementById("themeBtn");
      function applyTheme(next) {
        document.documentElement.setAttribute("data-theme", next);
        document.documentElement.classList.toggle("dark", next === "dark");
        localStorage.setItem("theme", next);
      }
      btn?.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme") || "dark";
        applyTheme(current === "dark" ? "light" : "dark");
      });
      applyTheme(localStorage.getItem("theme") || "dark");
    })();

    (function(){
      const params = new URLSearchParams(window.location.search);
      const status = params.get("subscribed");

      if (status === "1") {
        document.getElementById("subscribeSuccess")?.classList.remove("hidden");
      } else if (status === "invalid") {
        document.getElementById("subscribeInvalid")?.classList.remove("hidden");
      } else if (status === "error") {
        document.getElementById("subscribeError")?.classList.remove("hidden");
      }

      if (status) {
        window.history.replaceState({}, "", window.location.pathname);
      }
    })();

    (function(){
      const input = document.getElementById("searchInput");
      const cards = Array.from(document.querySelectorAll(".news-card"));
      const noResults = document.getElementById("noResults");

      function norm(str){
        return (str || "")
          .toString()
          .toLowerCase()
          .replace(/[\u064B-\u065F\u0670]/g, "")
          .replace(/[إأآا]/g, "ا")
          .replace(/ى/g, "ي")
          .replace(/ؤ/g, "و")
          .replace(/ئ/g, "ي")
          .replace(/ة/g, "ه")
          .replace(/\s+/g, " ")
          .trim();
      }

      input?.addEventListener("input", () => {
        const q = norm(input.value);
        let shown = 0;

        cards.forEach(card => {
          const text = norm(card.innerText);
          const ok = !q || text.includes(q);
          card.style.display = ok ? "" : "none";
          if (ok) shown++;
        });

        if (noResults) {
          noResults.classList.toggle("hidden", shown === 0);
        }
      });
    })();

    (function mobileNavInit(){
      const btn = document.getElementById("mobileNavBtn");
      const navDrawer = document.getElementById("mobileNavDrawer");
      const overlay = document.getElementById("mobileNavOverlay");
      const closeBtn = document.getElementById("mobileNavClose");

      function setOpenState(isOpen){
        btn?.setAttribute("data-open", isOpen ? "true" : "false");
        btn?.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }

      function openNav(){
        overlay?.classList.remove("hidden");
        navDrawer?.classList.add("isOpen");
        setOpenState(true);
      }
      function closeNav(){
        navDrawer?.classList.remove("isOpen");
        overlay?.classList.add("hidden");
        setOpenState(false);
      }

      btn?.addEventListener("click", () => {
        const open = btn.getAttribute("data-open") === "true";
        open ? closeNav() : openNav();
      });

      closeBtn?.addEventListener("click", closeNav);
      overlay?.addEventListener("click", closeNav);
      navDrawer?.querySelectorAll("a").forEach(a => a.addEventListener("click", closeNav));
      window.addEventListener("keydown", (e) => { if (e.key === "Escape") closeNav(); });

      setOpenState(false);
    })();
  </script>

</body>
</html>