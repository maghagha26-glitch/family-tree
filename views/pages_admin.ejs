                    <input name="bank_name" id="bank_name" value="<%= support?.bank_name || '' %>" placeholder="اسم البنك" class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-2.5 px-4"/>
                    <input name="account_number" id="account_number" value="<%= support?.account_number || '' %>" placeholder="رقم الحساب / الآيبان" class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-2.5 px-4"/>
                  </div>
