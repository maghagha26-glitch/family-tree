<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>لوحة الإدارة - إدارة الصفحات</title>

  <script src="/theme.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#005A2B",     /* البنفسجي الملكي */
            primaryDark: "#00361A", 
            accent: "#E5B869",      /* الذهب السائل */
            "bg-light": "#F5F3F7",  /* خلفية فاتحة دافئة */
            "bg-dark": "#050505",   /* خلفية داكنة جداً بلمحة بنفسجية */
            "card-light": "rgba(255, 255, 255, 0.8)",
            "card-dark": "rgba(15, 12, 25, 0.8)",
            "border-light": "rgba(0, 90, 43, 0.1)",
            "border-dark": "rgba(229, 184, 105, 0.1)",
          },
          fontFamily: {
            display: ["'Aref Ruqaa'", "serif"],
            sans: ["Tajawal", "sans-serif"],
          },
        }
      }
    };
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .glass-panel { @apply backdrop-blur-2xl shadow-xl; }
    }
  </style>

  <style>
    /* تخصيص شريط التمرير */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #005A2B; border-radius: 10px; }
    html.dark ::-webkit-scrollbar-thumb { background: #E5B869; }

    /* حقول الإدخال */
    .form-input { transition: all 0.3s ease; }
    .form-input:focus {
      box-shadow: 0 0 20px rgba(0, 90, 43, 0.15);
      border-color: #005A2B !important;
      transform: translateY(-1px);
    }
    html.dark .form-input:focus {
      box-shadow: 0 0 20px rgba(229, 184, 105, 0.15);
      border-color: #E5B869 !important;
    }

    /* صفوف الجدول الديناميكية */
    .interactive-row {
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      border-right: 3px solid transparent;
      border-radius: 12px;
    }
    .interactive-row:hover {
      background: #ffffff !important;
      border-right-color: #005A2B;
      transform: translateX(-4px) scale(1.01);
      box-shadow: 0 10px 30px rgba(0, 90, 43, 0.1);
      z-index: 10;
      position: relative;
    }
    html.dark .interactive-row:hover {
      background: #1A1525 !important;
      border-right-color: #E5B869;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
    }

    /* Dropzone helper للـ PDF */
    .dzActive {
      outline: 2px dashed rgba(0, 90, 43, 0.55);
      outline-offset: 6px;
      background: rgba(0, 90, 43, 0.04);
    }
    html.dark .dzActive {
      outline: 2px dashed rgba(229, 184, 105, 0.55);
      background: rgba(229, 184, 105, 0.06);
    }

    /* شبكة العائلة التفاعلية في الخلفية */
    #nexusCanvas {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 0; pointer-events: auto;
    }

    /* إعدادات أيقونات المظهر */
    html.dark .dark-toggle-icon-moon { display: none; }
    html:not(.dark) .dark-toggle-icon-sun { display: none; }

    /* Mobile Nav */
    #mobileNavOverlay.hidden { display: none; }
    #mobileNavOverlay { display: block; }
    #mobileNavDrawer { transform: translateX(110%); transition: transform .4s cubic-bezier(0.16, 1, 0.3, 1); }
    #mobileNavDrawer.isOpen { transform: translateX(0); }
  </style>

  <script>
    (function () {
      const saved = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-theme", saved);
      document.documentElement.classList.toggle("dark", saved === "dark");
    })();
  </script>
</head>

<body class="bg-bg-light dark:bg-bg-dark text-gray-800 dark:text-gray-200 font-sans h-screen flex overflow-hidden selection:bg-accent selection:text-primaryDark">

  <canvas id="nexusCanvas"></canvas>
  <div class="fixed inset-0 bg-gradient-to-b from-white/40 to-white/80 dark:from-black/40 dark:to-[#050505]/90 pointer-events-none z-[1]"></div>

  <aside class="relative z-20 hidden lg:flex flex-col w-[280px] h-[calc(100vh-2rem)] my-4 mx-4 bg-card-light dark:bg-card-dark glass-panel rounded-3xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
    
    <div class="flex items-center gap-3 p-6 border-b border-border-light dark:border-border-dark shrink-0">
      <div class="w-12 h-12 flex items-center justify-center rounded-2xl bg-primary dark:bg-accent text-white dark:text-black shadow-lg">
        <span class="material-symbols-outlined text-[28px]">shield_person</span>
      </div>
      <div>
        <h1 class="font-display font-bold text-xl leading-none text-primary dark:text-white">عائلة خاشقجي</h1>
        <p class="text-[10px] font-bold text-gray-500 dark:text-accent uppercase tracking-widest mt-1.5">نظام الإدارة المركزية</p>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-6">
      
      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">البيانات الرئيسية</p>

        <a href="/admin" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">group</span> إدارة الأفراد
        </a>

        <a href="/admin/pages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent font-bold text-sm border border-primary/20 dark:border-accent/20 transition-all relative overflow-hidden shadow-sm">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-6 rounded-l-full bg-primary dark:bg-accent shadow-[0_0_10px_rgba(229,184,105,0.8)]"></div>
          <span class="material-symbols-outlined text-[22px]">history_edu</span> إدارة الصفحات
        </a>

        <a href="/admin/honor" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">workspace_premium</span> السير الذاتية
        </a>

        <a href="/admin/news" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">newspaper</span> الأخبار والمناسبات
        </a>
      </div>

      <div class="space-y-2">
        <p class="px-3 text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">النظام والموقع</p>
        
        <a href="/admin/support-messages" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">mail</span> رسائل الدعم
        </a>
        
        <a href="/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-white dark:hover:bg-white/5 hover:text-primary dark:hover:text-accent font-bold text-sm transition-colors border border-transparent">
          <span class="material-symbols-outlined text-[22px]">account_tree</span> عرض الشجرة
        </a>
      </div>
    </nav>

    <div class="p-4 border-t border-border-light dark:border-border-dark shrink-0 m-2 rounded-2xl bg-white/50 dark:bg-black/30">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-cover bg-center border border-gray-200 dark:border-white/10 shadow-sm" style="background-image:url('/assets/default-avatar.png'); background-color: #ddd;"></div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-gray-900 dark:text-white truncate"><%= admin?.username || "مدير النظام" %></p>
          <p class="text-[10px] text-primary dark:text-accent uppercase tracking-widest mt-0.5 font-bold">Admin</p>
        </div>
        <form method="post" action="/admin/logout" class="m-0">
          <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm" title="تسجيل خروج">
            <span class="material-symbols-outlined text-[18px]">logout</span>
          </button>
        </form>
      </div>
    </div>
  </aside>

  <main class="flex-1 flex flex-col min-w-0 h-full relative z-10">
    
    <header class="flex items-center justify-between p-4 lg:p-8 shrink-0">
      <div class="flex items-center gap-3">
        <button id="mobileNavBtn" class="lg:hidden flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-primary dark:text-accent shadow-sm" type="button">
          <span class="material-symbols-outlined text-[24px]">menu</span>
        </button>

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary dark:text-white tracking-tight leading-none mb-1.5">إدارة الصفحات</h2>
          <div class="flex items-center gap-1.5 text-gray-500 text-[11px] font-bold uppercase tracking-widest">
            <span>لوحة الإدارة</span>
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            <span class="text-accent">إدارة المحتوى</span>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <button id="themeBtn" class="flex items-center justify-center w-12 h-12 rounded-2xl bg-card-light dark:bg-card-dark glass-panel border border-border-light dark:border-border-dark text-gray-600 dark:text-accent shadow-sm hover:-translate-y-1 transition-transform" type="button" title="تبديل المظهر">
          <span class="material-symbols-outlined text-[22px] dark-toggle-icon-moon">dark_mode</span>
          <span class="material-symbols-outlined hidden dark:block text-[24px]">light_mode</span>
        </button>

        <button id="saveAll" class="flex items-center gap-2 px-6 h-12 rounded-2xl font-bold text-sm bg-primary dark:bg-accent text-white dark:text-black shadow-[0_5px_20px_rgba(0,90,43,0.4)] dark:shadow-[0_5px_20px_rgba(229,184,105,0.20)] hover:-translate-y-1 transition-transform" type="button">
          <span class="material-symbols-outlined text-[22px]">save</span>
          <span class="hidden sm:inline">حفظ الكل</span>
        </button>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-4 lg:px-8 pb-12">
      <div class="max-w-[100rem] mx-auto space-y-8">

        <% if (saved) { %>
          <div class="bg-green-50/80 dark:bg-green-500/10 border border-green-200 dark:border-green-500/20 text-green-700 dark:text-green-400 px-6 py-4 rounded-2xl font-bold shadow-sm glass-panel flex items-center gap-3">
            <span class="material-symbols-outlined text-[24px]">check_circle</span>
            تم حفظ التعديلات بنجاح
          </div>
        <% } %>

        <section class="bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark shadow-sm overflow-hidden relative">
          <div class="absolute top-0 start-0 end-0 h-1 bg-gradient-to-l from-transparent via-accent to-transparent opacity-50"></div>
          
          <div class="p-6 md:p-8">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
              <div>
                <h3 class="text-xl font-display font-bold text-primary dark:text-white flex items-center gap-2 mb-1">
                  <span class="material-symbols-outlined text-accent">edit_note</span>
                  النبذة والمحطات التاريخية
                </h3>
                <p class="text-gray-500 text-sm font-bold">تحكم في المحتوى النصي للنبذة وأدر المحطات الزمنية لعائلتك.</p>
              </div>

              <div class="flex items-center gap-2 p-1.5 rounded-2xl bg-black/5 dark:bg-white/5 border border-border-light dark:border-border-dark">
                <button type="button" data-tab="aboutContentPane" class="aboutTab flex-1 px-6 py-2.5 rounded-xl text-sm font-bold transition-all bg-white dark:bg-[#1A1525] text-primary dark:text-accent shadow-sm border border-border-light dark:border-border-dark">
                  المحتوى النصي
                </button>
                <button type="button" data-tab="aboutTimelinePane" class="aboutTab flex-1 px-6 py-2.5 rounded-xl text-sm font-bold transition-all text-gray-500 dark:text-gray-400 hover:bg-white/50 dark:hover:bg-white/5">
                  المحطات التاريخية
                </button>
              </div>
            </div>

            <div id="aboutContentPane" class="aboutPane space-y-6">
              <form id="formAbout" method="post" action="/admin/pages/save">
                <input type="hidden" name="slug" value="about"/>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                  <label class="block">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">العنوان</span>
                    <input name="title" value="<%= about?.title || '' %>" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </label>
                  <label class="block">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">وصف مختصر</span>
                    <input name="subtitle" value="<%= about?.subtitle || '' %>" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </label>
                </div>

                <label class="block mb-6">
                  <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">المحتوى</span>
                  <textarea name="content" class="form-input mt-1 w-full h-80 p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-base leading-relaxed resize-y focus:ring-0" placeholder="ابدأ كتابة تاريخ العائلة هنا..."><%= about?.content || "" %></textarea>
                </label>

                <div class="flex items-center gap-3">
                  <button type="submit" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold transition-transform hover:-translate-y-1 bg-primary dark:bg-accent text-white dark:text-black shadow-md">
                    <span class="material-symbols-outlined text-[20px]">save</span> حفظ
                  </button>
                  <a href="/about" target="_blank" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold transition-all bg-white dark:bg-[#111] border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-300 hover:border-primary dark:hover:border-accent">
                    <span class="material-symbols-outlined text-[20px]">visibility</span> عرض الصفحة
                  </a>
                </div>
              </form>
            </div>

            <div id="aboutTimelinePane" class="aboutPane hidden">
              <form action="/admin/timeline/add" method="POST" enctype="multipart/form-data" class="mb-8 p-6 rounded-2xl border border-border-light dark:border-border-dark bg-black/5 dark:bg-white/5">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
                  <label class="block lg:col-span-2">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">عنوان المحطة</span>
                    <input type="text" name="title" required placeholder="مثال: تأسيس الوقف..." class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </label>
                  <label class="block">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">التاريخ</span>
                    <input type="text" name="date" required placeholder="مثال: أبريل 2026" class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </label>
                  <label class="block">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الترتيب</span>
                    <input type="number" name="order" value="0" class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                  </label>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  <label class="block">
                    <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الوصف</span>
                    <textarea name="description" rows="3" placeholder="تفاصيل الحدث..." class="form-input w-full rounded-xl bg-white dark:bg-black border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 resize-y focus:ring-0"></textarea>
                  </label>
                  <div class="flex flex-col gap-4">
                    <label class="block flex-grow">
                      <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">الصورة المرفقة</span>
                      <input type="file" name="image_file" accept="image/*" class="w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-black file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-bold file:bg-primary/10 file:text-primary dark:file:bg-accent/10 dark:file:text-accent text-gray-700 dark:text-gray-300 cursor-pointer p-1.5"/>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer mt-auto bg-white/50 dark:bg-black/30 p-3 rounded-xl border border-border-light dark:border-border-dark w-max">
                      <input type="checkbox" name="visible" value="1" checked class="w-5 h-5 rounded border-gray-300 text-primary dark:bg-black dark:border-gray-600 dark:checked:bg-accent focus:ring-0">
                      <span class="text-sm font-bold text-gray-800 dark:text-white">ظهور المحطة للعامة</span>
                    </label>
                  </div>
                </div>

                <div class="flex justify-end">
                  <button type="submit" class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold transition-transform hover:-translate-y-1 bg-primary dark:bg-accent text-white dark:text-black shadow-md">
                    <span class="material-symbols-outlined text-[20px]">add</span> إضافة المحطة
                  </button>
                </div>
              </form>

              <div class="overflow-x-auto custom-scrollbar rounded-2xl border border-border-light dark:border-border-dark bg-white/20 dark:bg-black/20">
                <table class="w-full text-start text-sm border-separate border-spacing-y-1 p-2">
                  <thead>
                    <tr>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-16">الترتيب</th>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px]">الصورة</th>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px]">العنوان</th>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px]">التاريخ</th>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px]">الحالة</th>
                      <th class="px-4 py-3 font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest text-[11px] w-32">إجراءات</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof timeline !== 'undefined' && timeline.length > 0) { %>
                      <% timeline.forEach(event => { %>
                        <tr class="interactive-row bg-gray-50/50 dark:bg-white/5 group">
                          <td class="px-4 py-3 text-gray-900 dark:text-white font-bold text-center rounded-r-xl"><%= event.order %></td>
                          <td class="px-4 py-3">
                            <% if(event.image_url){ %>
                              <img src="<%= event.image_url %>" alt="" class="w-16 h-10 object-cover rounded-lg shadow-sm border border-border-light dark:border-border-dark">
                            <% } else { %>
                              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-gray-200 dark:bg-white/10 text-gray-400">
                                <span class="material-symbols-outlined text-[20px]">image</span>
                              </span>
                            <% } %>
                          </td>
                          <td class="px-4 py-3 font-bold text-gray-900 dark:text-white truncate max-w-[200px]"><%= event.title %></td>
                          <td class="px-4 py-3 text-gray-600 dark:text-gray-400 font-bold"><%= event.date %></td>
                          <td class="px-4 py-3">
                            <% if(event.visible) { %>
                              <span class="inline-flex items-center px-2 py-1 rounded-md text-[10px] font-bold bg-green-100 text-green-700 dark:bg-primary/20 dark:text-green-400">ظاهر</span>
                            <% } else { %>
                              <span class="inline-flex items-center px-2 py-1 rounded-md text-[10px] font-bold bg-gray-200 text-gray-700 dark:bg-white/10 dark:text-gray-300">مخفي</span>
                            <% } %>
                          </td>
                          <td class="px-4 py-3 rounded-l-xl">
                            <div class="flex items-center gap-2 opacity-100 lg:opacity-0 group-hover:opacity-100 transition-opacity">
                              <a href="/admin/timeline/<%= event.id %>/edit" title="تعديل" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white dark:bg-[#111] border border-gray-200 hover:border-primary text-gray-600 hover:text-primary dark:border-white/10 dark:text-gray-400 dark:hover:border-accent dark:hover:text-accent transition-all shadow-sm">
                                <span class="material-symbols-outlined text-[16px]">edit</span>
                              </a>
                              <form action="/admin/timeline/<%= event.id %>/delete" method="POST" class="m-0" onsubmit="return confirm('هل أنت متأكد من حذف هذه المحطة بشكل نهائي؟');">
                                <button type="submit" title="حذف" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white dark:bg-[#111] border border-gray-200 hover:border-red-500 text-gray-600 hover:text-white hover:bg-red-500 dark:border-white/10 dark:text-gray-400 dark:hover:border-red-500/50 dark:hover:text-red-400 transition-all shadow-sm">
                                  <span class="material-symbols-outlined text-[16px]">delete</span>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="6" class="px-4 py-8 text-center text-gray-500 font-bold">لا توجد أي محطات تاريخية مضافة حتى الآن.</td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
          
          <form id="formTreePdf" method="post" action="/admin/pages/save" class="h-full">
            <input type="hidden" name="slug" value="tree-pdf"/>
            <section class="bg-card-light dark:bg-card-dark glass-panel rounded-[2rem] border border-border-light dark:border-border-dark p-6 md:p-8 flex flex-col h-full shadow-sm">
              <div class="mb-6">
                <h3 class="text-xl font-display font-bold text-primary dark:text-white flex items-center gap-2 mb-1">
                  <span class="material-symbols-outlined text-accent">description</span>
                  شجرة العائلة (PDF)
                </h3>
                <p class="text-gray-500 text-sm font-bold">تحديث بيانات الصفحة ورفع ملف PDF.</p>
              </div>

              <div class="grid grid-cols-1 gap-4 mb-6">
                <label class="block">
                  <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">العنوان</span>
                  <input name="title" value="<%= treepdf?.title || '' %>" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                </label>
                <label class="block">
                  <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">وصف مختصر</span>
                  <input name="subtitle" value="<%= treepdf?.subtitle || '' %>" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 focus:ring-0"/>
                </label>
                <label class="block">
                  <span class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest mb-2 block">محتوى أعلى الـ PDF</span>
                  <textarea name="content" rows="4" class="form-input w-full rounded-xl bg-white/50 dark:bg-black/20 border border-border-light dark:border-border-dark text-gray-900 dark:text-white font-bold text-sm py-3 px-4 resize-y focus:ring-0"><%= treepdf?.content || "" %></textarea>
                </label>
              </div>

              <div class="mb-8">
                <div class="flex items-center justify-between mb-3">
                  <p class="text-xs font-bold text-gray-500 dark:text-accent uppercase tracking-widest">ملف PDF الحالي</p>
                  <% if (treepdf?.pdf_url) { %>
                    <div class="flex items-center gap-2">
                      <a href="<%= treepdf.pdf_url %>" target="_blank" class="text-xs font-bold text-primary dark:text-accent hover:underline">فتح الملف</a>
                      <button type="button" id="btnDeletePdf" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 hover:bg-red-500 hover:text-white transition-colors">حذف</button>
                    </div>
                  <% } else { %>
                    <span class="text-xs font-bold text-gray-400">لا يوجد ملف مرفوع</span>
                  <% } %>
                </div>

                <div id="pdfDropzone" class="rounded-2xl border-2 border-dashed border-gray-300 dark:border-gray-700 bg-white/50 dark:bg-black/20 p-8 text-center cursor-pointer transition-all hover:border-primary dark:hover:border-accent">
                  <div class="flex flex-col items-center gap-3">
                    <div class="w-14 h-14 rounded-full bg-primary/10 dark:bg-accent/10 flex items-center justify-center text-primary dark:text-accent">
                      <span class="material-symbols-outlined text-[32px]">cloud_upload</span>
                    </div>
                    <div>
                      <p class="text-sm font-bold text-gray-900 dark:text-white">اسحب ملف PDF هنا أو اضغط للاختيار</p>
                      <p class="text-[11px] font-bold text-gray-500 mt-1 uppercase">حد أقصى 25MB</p>
                    </div>
                    <p id="pdfSelectedName" class="text-sm font-bold text-primary dark:text-accent hidden"></p>
                    <div class="flex items-center gap-2 mt-2">
                      <button type="button" id="btnUploadPdf" class="hidden items-center gap-2 px-5 py-2 rounded-xl text-sm font-bold transition-all bg-primary dark:bg-accent text-white dark:text-black">
                        <span class="material-symbols-outlined text-[20px]">upload</span> رفع الملف
